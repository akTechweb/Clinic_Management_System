@model IEnumerable<InfinityCoderzz_CMSV2026.Models.pharmacist.BillViewModel>

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Bills";
    ViewData["ActiveMenu"] = "Bills";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Pharmacy Bills</div>
        <div class="page-sub">All bills generated at the pharmacy counter</div>
    </div>
    <a asp-action="Create" class="btn-primary-cms">
        <i class="fa-solid fa-plus"></i> Create Bill
    </a>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-receipt"></i> Bill List</span>
        <span style="font-size:12px;color:#64748b;">@Model.Count() bills</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table js-datatable">
            <thead>
                <tr>
                    <th>Bill No.</th>
                    <th>Patient</th>
                    <th>Date</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="color:#94a3b8;font-size:12px;font-weight:600;">@RefNo.Bill(item.BillId)</td>
                            <td>
                                <div style="font-weight:600;font-size:13px;">
                                    @(item.PatientName ?? "Patient #" + item.PatientId)
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.PatientCode))
                                {
                                    <div style="font-size:11px;color:#94a3b8;">@item.PatientCode</div>
                                }
                            </td>
                            <td>@item.BillDate.ToString("dd MMM yyyy")</td>
                            <td style="font-weight:700;color:#198754;">₹@item.TotalAmount.ToString("0.00")</td>
                            <td>
                                @{
                                    var sc = item.Status?.ToLower() switch {
                                        "paid"    => "badge-success",
                                        "pending" => "badge-warn",
                                        "cancelled" or "canceled" => "badge-danger",
                                        _         => "badge-gray"
                                    };
                                }
                                <span class="badge-cms @sc">@(item.Status ?? "Pending")</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:32px;color:#94a3b8;">
                            <i class="fa-solid fa-receipt" style="font-size:28px;display:block;margin-bottom:8px;"></i>
                            No bills found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
