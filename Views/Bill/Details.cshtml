@model InfinityCoderzz_CMSV2026.Models.pharmacist.BillViewModel

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Bill Details";
    ViewData["ActiveMenu"] = "Bills";
    var items = ViewBag.Items as IEnumerable<InfinityCoderzz_CMSV2026.Models.pharmacist.BillItemViewModel>
                ?? Enumerable.Empty<InfinityCoderzz_CMSV2026.Models.pharmacist.BillItemViewModel>();
    var rxLink = ViewBag.PrescriptionLink as InfinityCoderzz_CMSV2026.Models.pharmacist.BillPrescriptionLink;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Bill Details</div>
        <div class="page-sub">Bill @RefNo.Bill(Model.BillId)</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="List" class="btn-outline-cms">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Bills
        </a>
        <a asp-action="Invoice" asp-route-id="@Model.BillId" target="_blank" class="btn-outline-cms">
            <i class="fa-solid fa-print me-1"></i> Print Invoice
        </a>
        <a asp-action="InvoicePdf" asp-route-id="@Model.BillId" class="btn-outline-cms">
            <i class="fa-solid fa-file-pdf me-1"></i> Download PDF
        </a>
        @if (Model.Status != "Cancelled")
        {
            <button type="button" class="btn-danger-cms" data-bs-toggle="modal" data-bs-target="#cancelModal">
                <i class="fa-solid fa-ban me-1"></i> Cancel Bill
            </button>
        }
    </div>
</div>

@if (Model.Status != "Cancelled")
{
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;">
                <form asp-action="Cancel" asp-route-id="@Model.BillId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fa-solid fa-ban text-danger me-2"></i>Cancel Bill @RefNo.Bill(Model.BillId)</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3">Cancelling this bill will restore the dispensed stock back to inventory. This action is recorded in the audit log.</p>
                        <label class="form-label-cms">Reason for cancellation <span class="req">*</span></label>
                        <textarea name="reason" rows="3" class="form-control-cms" required
                                  placeholder="Enter reason for cancelling this bill..."></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-outline-cms" data-bs-dismiss="modal">Keep Bill</button>
                        <button type="submit" class="btn-danger-cms">
                            <i class="fa-solid fa-ban"></i> Confirm Cancellation
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (rxLink != null)
{
    <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2">
        <span>
            <i class="fa-solid fa-file-prescription me-2"></i>
            Auto-generated from prescription <strong>@RefNo.Rx(rxLink.PrescriptionId)</strong>
            (Dispense <strong>@RefNo.Dispense(rxLink.DispenseId)</strong>) — stock was deducted once at dispensing.
        </span>
        <a asp-controller="Prescription" asp-action="Details" asp-route-id="@rxLink.PrescriptionId"
           class="btn-outline-cms btn-sm-cms">
            <i class="fa-solid fa-eye me-1"></i> View Prescription
        </a>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="cms-card h-100">
            <div class="cms-card-header">
                <span class="cms-card-title"><i class="fa-solid fa-user"></i> Patient Information</span>
            </div>
            <div class="p-3">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:140px;">Patient Code</td>
                        <td><strong>@Model.PatientCode</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Patient Name</td>
                        <td><strong>@Model.PatientName</strong></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="cms-card h-100">
            <div class="cms-card-header">
                <span class="cms-card-title"><i class="fa-solid fa-receipt"></i> Bill Information</span>
            </div>
            <div class="p-3">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:140px;">Bill No.</td>
                        <td><strong>@RefNo.Bill(Model.BillId)</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Bill Date</td>
                        <td>@Model.BillDate.ToString("dd MMM yyyy hh:mm tt")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Status</td>
                        <td>
                            @if (Model.Status == "Active")
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (Model.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">Cancelled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Total Amount</td>
                        <td><strong class="text-success fs-5">₹@Model.TotalAmount.ToString("N2")</strong></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-pills"></i> Bill Items</span>
        <span class="badge bg-secondary">@items.Count() item(s)</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Medicine</th>
                    <th class="text-center">Qty</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    int idx = 1;
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="text-muted">@idx</td>
                            <td style="font-weight:600;">@item.MedicineName</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">₹@item.UnitPrice.ToString("N2")</td>
                            <td class="text-end"><strong>₹@item.Amount.ToString("N2")</strong></td>
                        </tr>
                        idx++;
                    }
                    <tr style="background:#f8fafc;font-weight:700;">
                        <td colspan="4" class="text-end">TOTAL</td>
                        <td class="text-end text-success">₹@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No items found for this bill.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
