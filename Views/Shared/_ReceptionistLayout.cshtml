<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity Clinic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --blue: #2563eb;
            --blue-dark: #1d4ed8;
            --blue-light: #eff6ff;
            --green: #16a34a;
            --green-light: #f0fdf4;
            --orange: #ea580c;
            --orange-light: #fff7ed;
            --purple: #7c3aed;
            --purple-light: #f5f3ff;
            --sidebar-w: 210px;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --bg: #f8fafc;
            --surface: #fff;
            --radius: 10px;
            --shadow: 0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.06)
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
            font-size: 14px;
            color: var(--text);
            background: var(--bg);
            display: flex;
            min-height: 100vh
        }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            z-index: 100
        }

        .sidebar-brand {
            padding: 20px 16px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            background: var(--blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0
        }

        .brand-text .name {
            font-size: 14px;
            font-weight: 700;
            color: var(--text)
        }

        .brand-text .sub {
            font-size: 11px;
            color: var(--muted)
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--muted);
            padding: 14px 16px 4px
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            border-left: 3px solid transparent;
            transition: all .15s;
            cursor: pointer
        }

            .nav-link-item:hover {
                background: #f1f5f9;
                color: var(--text);
                border-left-color: #cbd5e1
            }

            .nav-link-item.active {
                background: var(--blue-light);
                color: var(--blue);
                border-left-color: var(--blue);
                font-weight: 600
            }

            .nav-link-item .nav-icon {
                font-size: 16px;
                width: 20px;
                text-align: center
            }

        .nav-logout {
            margin-top: auto;
            padding: 12px 16px;
            border-top: 1px solid var(--border)
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            font-size: 13px;
            font-weight: 500;
            color: #ef4444;
            background: #fef2f2;
            border: none;
            border-radius: 8px;
            width: 100%;
            cursor: pointer;
            transition: background .15s
        }

            .logout-btn:hover {
                background: #fee2e2
            }

        /* ── Main content ── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh
        }

        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 28px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            z-index: 50
        }

        .topbar-left h5 {
            font-size: 16px;
            font-weight: 700;
            margin: 0
        }

        .topbar-left p {
            font-size: 12px;
            color: var(--muted);
            margin: 0
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            color: var(--muted)
        }

        .page-body {
            padding: 24px 28px;
            flex: 1
        }

        /* ── Alerts ── */
        .cms-alert {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            border-radius: var(--radius);
            font-size: 13px;
            margin-bottom: 16px
        }

        .cms-alert-success {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #15803d
        }

        .cms-alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626
        }

        .cms-alert-info {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            color: #1d4ed8
        }

        .cms-alert-warn {
            background: #fffbeb;
            border: 1px solid #fde68a;
            color: #b45309
        }

        /* ── Stat cards ── */
        .stat-card {
            border-radius: 14px;
            padding: 18px 20px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 4px 12px rgba(0,0,0,.12)
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: rgba(255,255,255,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0
        }

        .stat-val {
            font-size: 28px;
            font-weight: 700;
            line-height: 1
        }

        .stat-lbl {
            font-size: 12px;
            opacity: .88;
            margin-top: 2px
        }

        .stat-sub {
            font-size: 11px;
            opacity: .75;
            margin-top: 4px
        }

        .stat-blue {
            background: linear-gradient(135deg,#3b82f6,#2563eb)
        }

        .stat-green {
            background: linear-gradient(135deg,#22c55e,#16a34a)
        }

        .stat-orange {
            background: linear-gradient(135deg,#fb923c,#ea580c)
        }

        .stat-purple {
            background: linear-gradient(135deg,#a78bfa,#7c3aed)
        }

        /* ── CMS Card ── */
        .cms-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow)
        }

        .cms-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 18px;
            border-bottom: 1px solid var(--border)
        }

        .cms-card-title {
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--blue)
        }

        .cms-card-body {
            padding: 18px
        }

        /* ── Buttons ── */
        .btn-primary-cms {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--blue);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s
        }

            .btn-primary-cms:hover {
                background: var(--blue-dark);
                color: #fff
            }

        .btn-success-cms {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #16a34a;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s
        }

            .btn-success-cms:hover {
                background: #15803d;
                color: #fff
            }

        .btn-warn-cms {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f59e0b;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s
        }

            .btn-warn-cms:hover {
                background: #d97706;
                color: #fff
            }

        .btn-danger-cms {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #ef4444;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s
        }

            .btn-danger-cms:hover {
                background: #dc2626;
                color: #fff
            }

        .btn-outline-cms {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--surface);
            color: var(--blue);
            border: 1px solid var(--blue);
            border-radius: 8px;
            padding: 8px 18px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: all .15s
        }

            .btn-outline-cms:hover {
                background: var(--blue-light);
                color: var(--blue)
            }

        .btn-sm-cms {
            padding: 5px 12px !important;
            font-size: 12px !important
        }

        /* ── Forms ── */
        .form-label-cms {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 5px
        }

        .req {
            color: #ef4444
        }

        .form-control-cms {
            width: 100%;
            padding: 9px 12px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            transition: border-color .15s,box-shadow .15s;
            font-family: inherit
        }

            .form-control-cms:focus {
                outline: none;
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(37,99,235,.12)
            }

            .form-control-cms::placeholder {
                color: #94a3b8
            }

        .input-group-cms {
            display: flex
        }

            .input-group-cms .prefix {
                padding: 9px 12px;
                background: #f8fafc;
                border: 1.5px solid var(--border);
                border-right: none;
                border-radius: 8px 0 0 8px;
                font-size: 13px;
                color: var(--muted)
            }

            .input-group-cms .form-control-cms {
                border-radius: 0 8px 8px 0
            }

        .readonly-field {
            background: #f8fafc;
            color: var(--muted)
        }

        /* ── Gender radio ── */
        .gender-wrap {
            display: flex;
            gap: 24px;
            align-items: center;
            padding: 4px 0
        }

        .gender-radio {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: var(--muted)
        }

            .gender-radio input {
                width: 16px;
                height: 16px;
                accent-color: var(--blue);
                cursor: pointer
            }

                .gender-radio input:checked ~ span {
                    color: var(--blue)
                }

        /* ── Table ── */
        .cms-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px
        }

            .cms-table th {
                padding: 10px 14px;
                text-align: left;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: var(--muted);
                background: #f8fafc;
                border-bottom: 1px solid var(--border)
            }

            .cms-table td {
                padding: 11px 14px;
                border-bottom: 1px solid #f1f5f9;
                vertical-align: middle
            }

            .cms-table tr:last-child td {
                border-bottom: none
            }

            .cms-table tbody tr:hover td {
                background: #fafbfc
            }

        .mmr-link {
            color: var(--blue);
            font-weight: 600;
            text-decoration: none
        }

            .mmr-link:hover {
                text-decoration: underline
            }

        /* ── Badges ── */
        .badge-cms {
            display: inline-flex;
            align-items: center;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600
        }

        .badge-success {
            background: #dcfce7;
            color: #15803d
        }

        .badge-warn {
            background: #fef9c3;
            color: #854d0e
        }

        .badge-danger {
            background: #fee2e2;
            color: #b91c1c
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8
        }

        .badge-gray {
            background: #f1f5f9;
            color: #475569
        }

        .badge-orange {
            background: #ffedd5;
            color: #c2410c
        }

        /* ── Info rows ── */
        .info-grid {
            display: grid;
            grid-template-columns: 160px 1fr;
            gap: 10px 4px;
            font-size: 13px
        }

        .info-key {
            color: var(--muted);
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px
        }

        .info-val {
            color: var(--text);
            font-weight: 500
        }

        .colon::after {
            content: ":"
        }

        /* ── Success page ── */
        .success-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #dcfce7;
            border: 3px solid #86efac;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 36px;
            position: relative
        }

            .success-circle::before, .success-circle::after {
                content: '✦';
                position: absolute;
                color: #86efac;
                font-size: 10px
            }

            .success-circle::before {
                top: -12px;
                left: 50%;
                transform: translateX(-50%)
            }

            .success-circle::after {
                bottom: -8px;
                right: 8px
            }

        .next-action-card {
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            cursor: pointer;
            text-decoration: none;
            transition: border-color .15s,box-shadow .15s;
            background: var(--surface)
        }

            .next-action-card:hover {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(37,99,235,.08)
            }

        .next-action-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0
        }

        /* ── Quick action row ── */
        .quick-action {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 8px;
            transition: opacity .15s
        }

            .quick-action:hover {
                opacity: .85
            }

            .quick-action .qa-icon {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                flex-shrink: 0
            }

        /* ── Token chip ── */
        .token-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #eff6ff;
            color: var(--blue);
            border: 1px solid #bfdbfe;
            border-radius: 6px;
            padding: 3px 10px;
            font-size: 13px;
            font-weight: 700
        }

        /* ── Summary row ── */
        .summary-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px
        }

        .summary-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px
        }

        .summary-val {
            font-size: 15px;
            font-weight: 700
        }

        .summary-lbl {
            font-size: 11px;
            color: var(--muted);
            text-align: center
        }

        /* ── Report stat card ── */
        .rpt-stat {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 4px
        }

        .rpt-stat-val {
            font-size: 22px;
            font-weight: 700
        }

        .rpt-stat-lbl {
            font-size: 12px;
            color: var(--muted)
        }

        .rpt-stat-trend {
            font-size: 11px;
            margin-top: 2px
        }

        .trend-up {
            color: #16a34a
        }

        .trend-down {
            color: #ef4444
        }

        /* ── Misc ── */
        .page-title {
            font-size: 20px;
            font-weight: 700;
            margin: 0
        }

        .page-sub {
            font-size: 13px;
            color: var(--muted);
            margin: 2px 0 0
        }

        .divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 16px 0
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--muted)
        }

            .empty-state .ei {
                font-size: 40px;
                margin-bottom: 8px
            }

        .tip-bar {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 12px;
            color: #1d4ed8;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 16px
        }

        .logout-btn {
            text-decoration: none;
            display: inline-block;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">💙</div>
            <div class="brand-text">
                <div class="name">Infinity Clinic</div>
                <div class="sub">Management System</div>
            </div>
        </div>
        <div class="nav-label">DASHBOARD MENU</div>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Receptionists" asp-action="Dashboard">
            <span class="nav-icon">🏠</span> Dashboard
        </a>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Register" ? "active" : "")" asp-controller="Patients" asp-action="Create">
            <span class="nav-icon">👤</span> Register Patient
        </a>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Search" ? "active" : "")" asp-controller="Patients" asp-action="Search">
            <span class="nav-icon">🔍</span> Search Patient
        </a>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Appointments" ? "active" : "")" asp-controller="Appointments" asp-action="Index">
            <span class="nav-icon">📅</span> Appointments
        </a>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Billing" ? "active" : "")" asp-controller="Bills" asp-action="Index">
            <span class="nav-icon">💳</span> Billing
        </a>
        <a class="nav-link-item @(ViewData["ActiveNav"]?.ToString() == "Reports" ? "active" : "")" asp-controller="ReceptionistReports" asp-action="Index">
            <span class="nav-icon">📊</span> Reports
        </a>

        <div class="nav-logout">
            <a asp-controller="Login"
               asp-action="Logout"
               class="logout-btn">
                <span>🚪</span> Logout
            </a>
        </div>
    </aside>

    <!-- Main -->
    <div class="main-wrap">
        <div class="topbar">
            <div class="topbar-left">
                <h5>@(ViewData["Title"] ?? "Receptionist Dashboard")</h5>
            </div>
            <div class="topbar-right">
                @if (ViewData["ShowTopbarInfo"] != null)
                {
                    <span>📅 @DateTime.Now.ToString("dd MMM yyyy")</span>
                    <span>🕐 @DateTime.Now.ToString("hh:mm tt")</span>
                    <span style="display:flex;align-items:center;gap:6px">
                        <span style="width:28px;height:28px;border-radius:50%;background:#f1f5f9;display:inline-flex;align-items:center;justify-content:center">👤</span>
                        Receptionist ▾
                    </span>
                }
                else
                {
                    <a asp-controller="Receptionists" asp-action="Dashboard" class="btn-outline-cms btn-sm-cms">← Dashboard</a>
                }
            </div>
        </div>

        <div class="page-body">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
