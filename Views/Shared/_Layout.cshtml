<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity CMS 2026</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:"Segoe UI",sans-serif; }
        body { min-height:100vh; background:linear-gradient(135deg,#eff6ff,#f8fafc,#ecfeff); display:flex; justify-content:center; align-items:center; }
        .wrapper { width:1220px; height:810px; background:rgba(255,255,255,0.87); backdrop-filter:blur(22px); border-radius:24px; box-shadow:0 20px 50px rgba(15,23,42,0.08); display:flex; overflow:hidden; }
        .sidebar { width:255px; background:#ffffff; border-right:1px solid #e5e7eb; padding:24px; display:flex; flex-direction:column; }
        .logo-icon { width:58px; height:58px; margin:0 auto 10px; border-radius:16px; background:linear-gradient(135deg,#3b82f6,#0ea5e9); display:flex; justify-content:center; align-items:center; color:white; font-size:24px; box-shadow:0 8px 20px rgba(59,130,246,.2); }
        .nav-link { display:flex; align-items:center; gap:12px; text-decoration:none; padding:12px 15px; border-radius:12px; margin-bottom:6px; color:#334155; font-weight:600; font-size:14px; transition:all 0.2s; }
        .nav-link:hover { background:#eff6ff; color:#2563eb; transform:translateX(2px); }
        .nav-link.active { background:linear-gradient(135deg,#dbeafe,#eff6ff); color:#2563eb; }
        .logout-btn { background:#fef2f2 !important; color:#dc2626 !important; margin-top:auto; }
        .logout-btn:hover { background:#fee2e2 !important; }
        .content { flex:1; padding:28px; overflow-y:auto; height:100%; }
        .form-control { width:100%; padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px; outline:none; margin-top:5px; transition:border-color .2s; }
        .form-control:focus { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.1); }
        .btn-custom { background:linear-gradient(135deg,#3b82f6,#0ea5e9); color:white; border:none; padding:10px 18px; border-radius:8px; font-weight:600; cursor:pointer; transition:opacity .2s; text-decoration:none; display:inline-block; }
        .btn-custom:hover { opacity:0.9; color:white; }
        .text-danger { color:#dc2626; }
        .mb-3 { margin-bottom:12px; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="sidebar">
            <div>
                <div style="text-align:center; margin-bottom:28px;">
                    <div class="logo-icon"><i class="fa-solid fa-heart-pulse"></i></div>
                    <h2 style="font-size:17px; color:#0f172a; margin-top:10px;">Infinity Clinic</h2>
                    <p style="font-size:11px; color:#64748b;">Management System 2026</p>
                </div>
                <div style="color:#94a3b8; font-size:10px; font-weight:700; margin-bottom:10px; letter-spacing:0.8px; padding-left:4px;">NAVIGATION</div>
                @{
                    var active = ViewData["ActiveMenu"]?.ToString() ?? "";
                }
                <a asp-controller="Doctor" asp-action="Dashboard" class="nav-link @(active == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-house"></i> Dashboard
                </a>
                <a asp-controller="Doctor" asp-action="ViewAppointments" class="nav-link @(active == "ViewAppointments" ? "active" : "")">
                    <i class="fa-solid fa-calendar-check"></i> View Appointments
                </a>
                <a asp-controller="Doctor" asp-action="HistoryAndReports" class="nav-link @(active == "HistoryAndReports" ? "active" : "")">
                    <i class="fa-solid fa-file-medical"></i> Patient History & Reports
                </a>
            </div>
            <a asp-controller="Doctor" asp-action="Logout" class="nav-link logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
        <div class="content">
            @RenderBody()
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
