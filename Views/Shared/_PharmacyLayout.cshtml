<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity Clinic Pharmacy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <style>
        :root {
            --green: #198754;
            --green-dark: #146c43;
            --green-light: #eaf4ee;
            --green-border: #a3cfbb;
            --blue: #0d6efd;
            --orange: #475569;
            --orange-light: #f8fafc;
            --red: #dc3545;
            --red-dark: #b02a37;
            --red-light: #fde8e8;
            --sidebar-w: 220px;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --bg: #f8fafc;
            --surface: #fff;
            --radius: 10px;
            --shadow: 0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.06)
        }
        * { box-sizing: border-box; margin: 0; padding: 0 }
        body {
            font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
            font-size: 14px;
            color: var(--text);
            background: var(--bg);
            display: flex;
            min-height: 100vh
        }
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            z-index: 100;
            overflow-y: auto
        }
        .sidebar-brand {
            padding: 18px 16px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px
        }
        .brand-icon {
            width: 40px; height: 40px;
            background: var(--green);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
            flex-shrink: 0
        }
        .brand-text .name { font-size: 14px; font-weight: 700; color: var(--text) }
        .brand-text .sub { font-size: 11px; color: var(--muted) }
        .nav-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--muted);
            padding: 14px 16px 4px
        }
        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            border-left: 3px solid transparent;
            transition: all .15s
        }
        .nav-link-item:hover { background: #f1f5f9; color: var(--text); border-left-color: #cbd5e1 }
        .nav-link-item.active { background: var(--green-light); color: var(--green); border-left-color: var(--green); font-weight: 600 }
        .nav-link-item .nav-icon { font-size: 15px; width: 18px; text-align: center }
        .nav-logout { margin-top: auto; padding: 12px 16px; border-top: 1px solid var(--border) }
        .logout-btn {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 12px; font-size: 13px; font-weight: 500;
            color: #64748b; background: #f8fafc;
            border: none; border-radius: 8px; width: 100%;
            cursor: pointer; text-decoration: none; transition: background .15s
        }
        .logout-btn:hover { background: #f1f5f9 }
        .main-wrap { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh }
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 28px; height: 56px;
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0; position: sticky; top: 0; z-index: 50
        }
        .topbar-left h5 { font-size: 16px; font-weight: 700; margin: 0 }
        .topbar-left p { font-size: 12px; color: var(--muted); margin: 0 }
        .topbar-right { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--muted) }
        .page-body { padding: 24px 28px; flex: 1 }
        .cms-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow) }
        .cms-card-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid var(--border) }
        .cms-card-title { font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; color: var(--green) }
        .cms-card-body { padding: 18px }
        .stat-card { border-radius: 14px; padding: 18px 20px; color: #fff; display: flex; align-items: center; gap: 16px; box-shadow: 0 4px 12px rgba(0,0,0,.12) }
        .stat-icon { width: 52px; height: 52px; border-radius: 12px; background: rgba(255,255,255,.2); display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0 }
        .stat-val { font-size: 28px; font-weight: 700; line-height: 1 }
        .stat-lbl { font-size: 12px; opacity: .88; margin-top: 2px }
        .stat-green { background: linear-gradient(135deg,#1aa06a,#146c43) }
        .stat-blue { background: linear-gradient(135deg,#3d8bfd,#0a58ca) }
        .stat-orange { background: linear-gradient(135deg,#198754,#0f5132) }
        .stat-red { background: linear-gradient(135deg,#0d6efd,#084298) }
        .stat-purple { background: linear-gradient(135deg,#6ea8fe,#0d6efd) }
        .cms-table { width: 100%; border-collapse: collapse; font-size: 13px }
        .cms-table th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); background: #f8fafc; border-bottom: 1px solid var(--border) }
        .cms-table td { padding: 11px 14px; border-bottom: 1px solid #f1f5f9; vertical-align: middle }
        .cms-table tr:last-child td { border-bottom: none }
        .cms-table tbody tr:hover td { background: #fafbfc }
        .cms-table tr.alert-row td { background: var(--red-light) }
        .cms-table tr.alert-row td:first-child { box-shadow: inset 3px 0 0 var(--red) }
        .cms-table tr.alert-row:hover td { background: #fcdada }
        .badge-cms { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600 }
        .badge-success { background: #d1e7dd; color: #146c43 }
        .badge-warn { background: #f1f5f9; color: #475569 }
        .badge-danger { background: #fde8e8; color: #b02a37 }
        .badge-blue { background: #cfe2ff; color: #0a58ca }
        .badge-gray { background: #f1f5f9; color: #475569 }
        .badge-orange { background: #f1f5f9; color: #475569 }
        .btn-primary-cms { display: inline-flex; align-items: center; gap: 6px; background: var(--green); color: #fff; border: none; border-radius: 8px; padding: 9px 20px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; transition: background .15s }
        .btn-primary-cms:hover { background: var(--green-dark); color: #fff }
        .btn-danger-cms { display: inline-flex; align-items: center; gap: 6px; background: #64748b; color: #fff; border: none; border-radius: 8px; padding: 9px 20px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; transition: background .15s }
        .btn-danger-cms:hover { background: #475569; color: #fff }
        .btn-outline-cms { display: inline-flex; align-items: center; gap: 6px; background: var(--surface); color: var(--green); border: 1px solid var(--green); border-radius: 8px; padding: 8px 18px; font-size: 13px; font-weight: 500; cursor: pointer; text-decoration: none; transition: all .15s }
        .btn-outline-cms:hover { background: var(--green-light); color: var(--green) }
        .btn-sm-cms { padding: 5px 12px !important; font-size: 12px !important }
        .page-title { font-size: 20px; font-weight: 700; margin: 0 }
        .page-sub { font-size: 13px; color: var(--muted); margin-top: 2px }
        .form-label-cms { display: block; font-size: 12px; font-weight: 600; color: var(--text); margin-bottom: 5px }
        .req { color: #64748b }
        .form-control-cms { width: 100%; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 13px; color: var(--text); background: var(--surface); transition: border-color .15s,box-shadow .15s; font-family: inherit }
        .form-control-cms:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 3px rgba(25,135,84,.12) }
        .cms-alert { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: var(--radius); font-size: 13px; margin-bottom: 16px }
        .cms-alert-success { background: #eaf4ee; border: 1px solid #a3cfbb; color: #146c43 }
        .cms-alert-danger { background: #f8fafc; border: 1px solid #e2e8f0; color: #475569 }
        .cms-alert-warn { background: #f8fafc; border: 1px solid #e2e8f0; color: #475569 }
        /* Two-color palette: fold Bootstrap semantic utilities into blue/green + neutral grays */
        .text-success { color: #198754 !important }
        .text-danger, .text-warning, .text-info { color: #475569 !important }
        .bg-success { background-color: #198754 !important }
        .bg-danger, .bg-warning, .bg-info { background-color: #475569 !important }
        .badge.bg-success { background-color: #198754 !important; color: #fff !important }
        .badge.bg-danger, .badge.bg-warning, .badge.bg-info { background-color: #475569 !important; color: #fff !important }
        .btn-danger, .btn-warning { background-color: #475569 !important; border-color: #475569 !important; color: #fff !important }
        .btn-danger:hover, .btn-warning:hover { background-color: #334155 !important; border-color: #334155 !important; color: #fff !important }
        .btn-outline-danger { color: #475569 !important; border-color: #475569 !important }
        .btn-outline-danger:hover { background-color: #475569 !important; color: #fff !important }
        .btn-outline-success { color: #198754 !important; border-color: #198754 !important }
        .btn-outline-success:hover { background-color: #198754 !important; color: #fff !important }
        .alert-success { color: #0f5132 !important; background-color: #eaf4ee !important; border-color: #a3cfbb !important }
        .alert-danger, .alert-warning, .alert-info { color: #334155 !important; background-color: #f1f5f9 !important; border-color: #cbd5e1 !important }
        .border-success { border-color: #198754 !important }
        .border-danger, .border-warning { border-color: #475569 !important }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon"><i class="fa-solid fa-pills"></i></div>
        <div class="brand-text">
            <div class="name">Infinity Clinic</div>
            <div class="sub">Pharmacy Module</div>
        </div>
    </div>

    @{
        var activeMenu = ViewData["ActiveMenu"]?.ToString() ?? "";
    }

    <div class="nav-label">Main</div>
    <a asp-controller="PharmacyDashboard" asp-action="Index"
       class="nav-link-item @(activeMenu == "Dashboard" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-house"></i></span> Dashboard
    </a>

    <div class="nav-label">Medicines</div>
    <a asp-controller="Medicines" asp-action="List"
       class="nav-link-item @(activeMenu == "Medicines" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-capsules"></i></span> All Medicines
    </a>
    <a asp-controller="MedicineStock" asp-action="List"
       class="nav-link-item @(activeMenu == "MedicineStock" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-boxes-stacked"></i></span> Stock Batches
    </a>
    <a asp-controller="MedicineStock" asp-action="LowStock"
       class="nav-link-item @(activeMenu == "LowStock" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-triangle-exclamation"></i></span> Low Stock
    </a>
    <a asp-controller="MedicineStock" asp-action="ExpiringMedicines"
       class="nav-link-item @(activeMenu == "Expiring" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-clock"></i></span> Expiring Soon
    </a>
    <a asp-controller="MedicineStock" asp-action="ExpiredMedicines"
       class="nav-link-item @(activeMenu == "Expired" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-ban"></i></span> Expired
    </a>
    <a asp-controller="InventoryLog" asp-action="List"
       class="nav-link-item @(activeMenu == "InventoryLog" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-list-check"></i></span> Inventory Log
    </a>

    <div class="nav-label">Dispensing &amp; Billing</div>
    <a asp-controller="Prescription" asp-action="List"
       class="nav-link-item @(activeMenu == "Prescriptions" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-file-prescription"></i></span> Prescriptions
    </a>
    <a asp-controller="MedicineDispensing" asp-action="Create"
       class="nav-link-item @(activeMenu == "Dispensing" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-hand-holding-medical"></i></span> Dispense Medicine
    </a>
    <a asp-controller="Bill" asp-action="List"
       class="nav-link-item @(activeMenu == "Bills" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-receipt"></i></span> Bills
    </a>
    <a asp-controller="MedicineDispensing" asp-action="History"
       class="nav-link-item @(activeMenu == "DispensingHistory" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-clock-rotate-left"></i></span> Dispensing History
    </a>

    <div class="nav-label">Analytics</div>
    <a asp-controller="Reports" asp-action="Index"
       class="nav-link-item @(activeMenu == "Reports" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-chart-column"></i></span> Reports
    </a>
    <a asp-controller="AuditLog" asp-action="List"
       class="nav-link-item @(activeMenu == "AuditLogs" ? "active" : "")">
        <span class="nav-icon"><i class="fa-solid fa-clipboard-list"></i></span> Audit Logs
    </a>

    <div class="nav-logout">
        <a asp-controller="Login" asp-action="Logout" class="logout-btn">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>
</div>

<div class="main-wrap">
    <div class="topbar">
        <div class="topbar-left">
            <h5>@(ViewData["Title"] ?? "Pharmacy")</h5>
        </div>
        <div class="topbar-right">
            <i class="fa-solid fa-user-nurse"></i>
            <span>@(Context.Session.GetString("PharmacistName") ?? "Pharmacist")</span>
        </div>
    </div>

    <div class="page-body">
        @if (TempData["Success"] != null)
        {
            <div class="cms-alert cms-alert-success">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="cms-alert cms-alert-danger">
                <i class="fa-solid fa-circle-xmark"></i>
                <span>@TempData["Error"]</span>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // Opt-in client-side search/sort/pagination: add class "js-datatable" to any table.
    $(function () {
        $('table.js-datatable').each(function () {
            var $table = $(this);
            // Skip empty tables. An empty-state row uses a single <td colspan="...">,
            // which DataTables miscounts as a 1-cell data row and reports the
            // "Incorrect column count" (tn/18) warning. Only initialise when there
            // is real tabular data.
            if ($table.find('tbody > tr').length === 0 ||
                $table.find('tbody > tr > td[colspan]').length > 0) {
                return;
            }
            $table.DataTable({
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                order: [],
                language: { search: "", searchPlaceholder: "Search..." }
            });
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
