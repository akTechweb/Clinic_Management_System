@model List<InfinityCoderzz_CMSV2026.Models.PatientReportSearchViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Patient History & Reports";
    ViewData["ActiveMenu"] = "HistoryAndReports";
}

<h2 style="color:#0f172a; font-size:22px; font-weight:700; margin-bottom:18px;">
    <i class="fa-solid fa-clock-rotate-left"></i> Patient History & Reports
</h2>

<!-- Search -->
<div style="background:white; padding:18px; border-radius:12px; border:1px solid #e2e8f0; margin-bottom:20px;">
    <form asp-action="HistoryAndReports" method="get" style="display:flex; gap:10px; align-items:center;">
        <input type="text" name="searchKeyword" class="form-control"
               style="flex:1; padding:11px 14px; margin-top:0;"
               placeholder="Search by MMR Code, Patient Name or Mobile..."
               value="@ViewBag.SearchKeyword" />
        <button type="submit" class="btn-custom" style="padding:11px 24px;">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchKeyword as string))
        {
            <a asp-action="HistoryAndReports" class="btn-custom" style="background:#64748b; padding:11px 18px;">
                <i class="fa-solid fa-xmark"></i> Clear
            </a>
        }
    </form>
</div>

<div style="display:grid; grid-template-columns:320px 1fr; gap:20px; height:calc(100vh - 280px); min-height:360px;">

    <!-- Patient list -->
    <div style="background:white; border-radius:12px; border:1px solid #e2e8f0; overflow-y:auto; padding:14px;">
        <h4 style="color:#475569; font-size:13px; font-weight:700; margin-bottom:12px; border-bottom:1px solid #f1f5f9; padding-bottom:6px;">
            @(Model?.Count ?? 0) Patient(s) Found
        </h4>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var p in Model)
            {
                <div style="padding:12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:10px;">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <p style="margin:0 0 3px; font-weight:700; color:#1e293b; font-size:14px;">@p.FullName</p>
                            <p style="margin:0; font-size:12px; color:#2563eb; font-weight:600;">MMR: @p.MMRCode</p>
                            <p style="margin:2px 0 0; font-size:12px; color:#64748b;">@p.MobileNumber</p>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <button type="button" class="btn-custom" style="padding:6px 12px; font-size:12px;"
                                    onclick="loadReports('@p.MMRCode')">
                                <i class="fa-solid fa-eye"></i> View Reports
                            </button>
                            <a href="/Doctor/PrintReport?mmrCode=@p.MMRCode" target="_blank"
                               class="btn-custom" style="padding:6px 12px; font-size:12px; background:#e11d48; text-align:center;">
                                <i class="fa-solid fa-file-pdf"></i> PDF
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align:center; padding:40px 20px; color:#94a3b8;">
                <i class="fa-solid fa-magnifying-glass fa-2x" style="opacity:0.4; margin-bottom:10px;"></i>
                <p style="font-size:13px; font-style:italic;">Search a patient to see results.</p>
            </div>
        }
    </div>

    <!-- Report panel -->
    <div id="reportPanel" style="background:white; border-radius:12px; border:1px solid #e2e8f0; padding:20px; overflow-y:auto;">
        <div style="text-align:center; margin-top:80px; color:#94a3b8;">
            <i class="fa-solid fa-flask-vial fa-3x" style="opacity:0.35; margin-bottom:12px; display:block;"></i>
            <p style="font-size:14px;">Select a patient to view their lab reports.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadReports(mmrCode) {
            var panel = document.getElementById('reportPanel');
            panel.innerHTML = '<div style="text-align:center;margin-top:80px;"><i class="fa-solid fa-spinner fa-spin fa-2x" style="color:#3b82f6;"></i><p style="color:#64748b;margin-top:10px;font-size:13px;">Loading reports...</p></div>';
            fetch('/Doctor/ViewLabReportDetails?mmrCode=' + encodeURIComponent(mmrCode))
                .then(r => r.text())
                .then(html => { panel.innerHTML = html; })
                .catch(() => { panel.innerHTML = '<div style="color:#ef4444;text-align:center;padding:30px;">Error loading reports.</div>'; });
        }
    </script>
}
