@model List<InfinityCoderzz_CMSV2026.Models.AppointmentViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "View Appointments";
    ViewData["ActiveMenu"] = "ViewAppointments";
    string active = ViewBag.CurrentSelection ?? "today";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <h2 style="color:#0f172a; font-size:22px; font-weight:700;">
        <i class="fa-solid fa-calendar-days"></i>
        @(active == "tomorrow" ? "Tomorrow's" : "Today's") Appointments
    </h2>
    <div style="background:#f1f5f9; padding:4px; border-radius:10px; display:flex; gap:4px;">
        <a asp-action="ViewAppointments" asp-route-targetDay="today"
           style="padding:9px 20px; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px;
                  @(active=="today" ? "background:linear-gradient(135deg,#3b82f6,#0ea5e9); color:white;" : "color:#475569;")">
            <i class="fa-solid fa-sun"></i> Today
        </a>
        <a asp-action="ViewAppointments" asp-route-targetDay="tomorrow"
           style="padding:9px 20px; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px;
                  @(active=="tomorrow" ? "background:linear-gradient(135deg,#3b82f6,#0ea5e9); color:white;" : "color:#475569;")">
            <i class="fa-solid fa-forward"></i> Tomorrow
        </a>
    </div>
</div>

<div style="background:white; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.04);">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
            <tr style="background:#f8fafc; color:#475569; border-bottom:2px solid #e2e8f0;">
                <th style="padding:14px 16px;">Token</th>
                <th style="padding:14px 16px;">MMR Code</th>
                <th style="padding:14px 16px;">Patient Name</th>
                <th style="padding:14px 16px;">Age</th>
                <th style="padding:14px 16px;">Gender</th>
                <th style="padding:14px 16px;">Mobile</th>
                <th style="padding:14px 16px;">Time</th>
                <th style="padding:14px 16px;">Status</th>
                <th style="padding:14px 16px; text-align:center;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="9" style="padding:40px; text-align:center; color:#94a3b8; font-weight:500;">
                        <i class="fa-solid fa-calendar-xmark fa-2x" style="display:block; margin-bottom:10px; opacity:0.4;"></i>
                        No appointments found for @(active == "tomorrow" ? "tomorrow" : "today").
                    </td>
                </tr>
            }
            else
            {
                foreach (var p in Model)
                {
                    <tr style="border-bottom:1px solid #f1f5f9; transition:background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                        <td style="padding:14px 16px; font-weight:700; color:#0f172a;">#@p.TokenNumber.ToString("D2")</td>
                        <td style="padding:14px 16px; color:#2563eb; font-weight:600;">@p.MMRCode</td>
                        <td style="padding:14px 16px; font-weight:600; color:#1e293b;">@p.FullName</td>
                        <td style="padding:14px 16px; color:#475569;">@p.Age yrs</td>
                        <td style="padding:14px 16px;">
                            <span style="background:#f1f5f9; padding:3px 10px; border-radius:6px; font-size:12px; font-weight:600;">@p.Gender</span>
                        </td>
                        <td style="padding:14px 16px; color:#64748b;">@p.MobileNumber</td>
                        <td style="padding:14px 16px; color:#64748b;">@p.AppointmentTime</td>
                        <td style="padding:14px 16px;">
                            @{
                                var (bg, fg, label) = p.Status switch
                                {
                                    "Completed"  => ("#dcfce7", "#15803d", "Completed"),
                                    "InProgress" => ("#dbeafe", "#1d4ed8", "In Progress"),
                                    _            => ("#fef3c7", "#b45309", "Pending")
                                };
                            }
                            <span style="padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600; background:@bg; color:@fg;">@label</span>
                        </td>
                        <td style="padding:14px 16px; text-align:center;">
                            @if (p.Status == "Completed")
                            {
                                <button disabled style="padding:7px 14px; border-radius:8px; border:none; background:#e2e8f0; color:#94a3b8; font-size:13px; cursor:not-allowed;">
                                    <i class="fa-solid fa-check-double"></i> Done
                                </button>
                            }
                            else
                            {
                                <a asp-action="StartConsultation" asp-route-appointmentId="@p.AppointmentId"
                                   class="btn-custom" style="padding:7px 14px; font-size:13px; background:linear-gradient(135deg,#10b981,#059669);">
                                    <i class="fa-solid fa-stethoscope"></i> Start Consultation
                                </a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
