@model InfinityCoderzz_CMSV2026.Models.Bill

@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Billing";
    ViewData["ActiveNav"] = "Billing";
    ViewData["ShowTopbarInfo"] = true;

    var appt = ViewBag.Appointment as InfinityCoderzz_CMSV2026.Models.Appointment;

    decimal consultationFee = appt?.ConsultationFee ?? 0;
    decimal registrationFee = 0;
    decimal total = consultationFee + registrationFee;
}

<div class="mb-3">
    <h4 class="page-title">Billing</h4>
    <p class="page-sub">Generate bill for consultation and registration fee.</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="cms-alert cms-alert-danger">
        ⚠ @TempData["ErrorMessage"]
    </div>
}

@if (appt != null)
{
    <div class="cms-card mb-3">
        <div class="cms-card-header">
            <span class="cms-card-title">📅 Appointment Information</span>
        </div>

        <div class="cms-card-body">
            <div class="row g-2" style="font-size:13px">

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Appointment No</span>
                    <span class="colon"></span>
                    <span style="font-weight:700">
                        @(appt.AppointmentNumber ?? "—")
                    </span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Patient Name</span>
                    <span class="colon"></span>
                    <span style="font-weight:600">@appt.PatientName</span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">MMR No</span>
                    <span class="colon"></span>
                    <span style="color:var(--blue);font-weight:700">
                        @appt.PatientCode
                    </span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Department</span>
                    <span class="colon"></span>
                    <span>@appt.DepartmentName</span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Doctor</span>
                    <span class="colon"></span>
                    <span>Dr. @appt.DoctorName</span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Appointment Date</span>
                    <span class="colon"></span>
                    <span>@appt.AppointmentDate.ToString("dd-MM-yyyy")</span>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <span style="color:var(--muted)">Time</span>
                    <span class="colon"></span>
                    <span>@appt.AppointmentTime.ToString(@"hh\:mm")</span>
                </div>

            </div>
        </div>
    </div>
}

<form asp-action="Create" method="post" id="billForm">
    <input type="hidden" name="patientId" value="@Model.PatientId" />
    <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />

    <div class="row g-3">

        <div class="col-md-7">
            <div class="cms-card">
                <div class="cms-card-header">
                    <span class="cms-card-title">📄 Billing Details</span>
                </div>

                <div class="cms-card-body">

                    <table class="cms-table mb-3">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Description</th>
                                <th style="text-align:right">Amount (₹)</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>Consultation Fee</td>
                                <td style="text-align:right">
                                    <input type="number"
                                           id="consultationFee"
                                           name="consultationFee"
                                           class="form-control-cms"
                                           style="width:130px;margin-left:auto;text-align:right"
                                           value="@consultationFee.ToString("F2")"
                                           step="0.01"
                                           min="0"
                                           readonly />
                                </td>
                            </tr>

                            <tr>
                                <td>2</td>
                                <td>Registration Fee</td>
                                <td style="text-align:right">
                                    <input type="number"
                                           id="registrationFee"
                                           name="registrationFee"
                                           class="form-control-cms"
                                           style="width:130px;margin-left:auto;text-align:right"
                                           value="@registrationFee.ToString("F2")"
                                           step="0.01"
                                           min="0"
                                           oninput="calculateTotal()" />
                                </td>
                            </tr>

                            <tr style="font-weight:700;font-size:14px">
                                <td colspan="2"
                                    style="text-align:right;color:var(--text)">
                                    Total Amount
                                </td>

                                <td style="text-align:right;color:var(--green);font-size:18px">
                                    ₹ <span id="totalDisplay">@total.ToString("F2")</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label-cms">
                                Payment Method <span class="req">*</span>
                            </label>

                            <select name="PaymentMethod"
                                    class="form-control-cms"
                                    id="paymentMethod"
                                    required>
                                <option value="Cash">Cash</option>
                                <option value="Card">Card</option>
                                <option value="UPI">UPI</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-cms">
                                Amount Received <span class="req">*</span>
                            </label>

                            <input type="number"
                                   name="amountReceived"
                                   id="amountReceived"
                                   class="form-control-cms"
                                   value="@total.ToString("F2")"
                                   step="0.01"
                                   min="0"
                                   oninput="calculateBalance()"
                                   required />
                        </div>

                        <div class="col-12">
                            <label class="form-label-cms">
                                Notes
                            </label>

                            <textarea name="notes"
                                      class="form-control-cms"
                                      rows="2"
                                      placeholder="Optional notes"></textarea>
                        </div>

                    </div>

                    <div class="d-flex gap-3 mt-3">
                        <button type="submit"
                                class="btn-success-cms"
                                onclick="return confirm('Generate bill?')">
                            📋 Generate Bill
                        </button>

                        <a asp-controller="Appointments"
                           asp-action="Index"
                           class="btn-outline-cms">
                            Cancel
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="cms-card">
                <div class="cms-card-header">
                    <span class="cms-card-title">📋 Bill Summary</span>
                </div>

                <div class="cms-card-body">
                    <div style="font-size:13px">

                        <div class="d-flex justify-content-between py-2"
                             style="border-bottom:1px solid var(--border)">
                            <span style="color:var(--muted)">Consultation Fee</span>
                            <span id="summaryConsultation">
                                ₹ @consultationFee.ToString("F2")
                            </span>
                        </div>

                        <div class="d-flex justify-content-between py-2"
                             style="border-bottom:1px solid var(--border)">
                            <span style="color:var(--muted)">Registration Fee</span>
                            <span id="summaryRegistration">
                                ₹ @registrationFee.ToString("F2")
                            </span>
                        </div>

                        <div class="d-flex justify-content-between py-2"
                             style="border-bottom:1px solid var(--border);font-weight:600">
                            <span>Total Amount</span>
                            <span id="summaryTotal"
                                  style="color:var(--green)">
                                ₹ @total.ToString("F2")
                            </span>
                        </div>

                        <div class="d-flex justify-content-between py-2"
                             style="border-bottom:1px solid var(--border);color:var(--green);font-weight:600">
                            <span>Amount Received</span>
                            <span id="summaryReceived">
                                ₹ @total.ToString("F2")
                            </span>
                        </div>

                        <div class="d-flex justify-content-between py-3"
                             style="background:#f0fdf4;border-radius:8px;padding:12px 14px;margin-top:8px">
                            <span style="font-weight:700">Balance Amount</span>
                            <span id="summaryBalance"
                                  style="font-weight:700;color:var(--green)">
                                ₹ 0.00
                            </span>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</form>

<div class="tip-bar mt-3"
     style="color:var(--orange);border-color:#fed7aa;background:#fff7ed">
    ⚠ Receptionist should collect only consultation fee and registration fee.
</div>

@section Scripts {

    <script>

        function calculateTotal()
        {
            const consultation =
                parseFloat(document.getElementById('consultationFee').value) || 0;

            const registration =
                parseFloat(document.getElementById('registrationFee').value) || 0;

            const total = consultation + registration;

            document.getElementById('totalDisplay').textContent =
                total.toFixed(2);

            document.getElementById('summaryConsultation').textContent =
                '₹ ' + consultation.toFixed(2);

            document.getElementById('summaryRegistration').textContent =
                '₹ ' + registration.toFixed(2);

            document.getElementById('summaryTotal').textContent =
                '₹ ' + total.toFixed(2);

            calculateBalance();
        }

        function calculateBalance()
        {
            const total =
                parseFloat(document.getElementById('totalDisplay').textContent) || 0;

            const received =
                parseFloat(document.getElementById('amountReceived').value) || 0;

            const balance = received - total;

            document.getElementById('summaryReceived').textContent =
                '₹ ' + received.toFixed(2);

            document.getElementById('summaryBalance').textContent =
                '₹ ' + balance.toFixed(2);

            document.getElementById('summaryBalance').style.color =
                balance < 0 ? 'var(--danger)' : 'var(--green)';
        }

        calculateTotal();

    </script>

}