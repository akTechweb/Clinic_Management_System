@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Appointment Booked Successfully";
    ViewData["ActiveNav"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="page-title">Appointment Booked Successfully</h4>
        <p class="page-sub">The appointment has been saved and token has been generated.</p>
    </div>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn-outline-cms">
        ← Back to Dashboard
    </a>
</div>

<div class="cms-card" style="max-width:760px;margin:0 auto;padding:40px 32px;text-align:center">
    <div class="success-circle">✓</div>

    <h4 style="color:var(--green);font-size:20px;font-weight:700;margin-bottom:6px">
        Appointment Booked Successfully! Token Generated
    </h4>

    <p style="color:var(--muted);font-size:13px;margin-bottom:28px">
        Please share the token number with the patient.
    </p>

    <div style="background:#f8fafc;border:1px solid var(--border);border-radius:var(--radius);padding:24px 32px;text-align:left;margin-bottom:28px">
        <div class="info-grid" style="gap:14px 8px">

            <span class="info-key">Appointment No <span class="colon"></span></span>
            <span class="info-val" style="font-family:monospace;font-size:13px;color:var(--blue);font-weight:700">
                @(ViewBag.AppointmentNumber ?? "—")
            </span>

            <span class="info-key">Token Number <span class="colon"></span></span>
            <span class="info-val" style="color:var(--green);font-size:18px;font-weight:700">
                T@(ViewBag.TokenNumber?.ToString().PadLeft(3, '0') ?? "000")
            </span>

            <span class="info-key">MMR No <span class="colon"></span></span>
            <span class="info-val" style="color:var(--blue);font-weight:700">
                @(ViewBag.PatientCode ?? "—")
            </span>

            <span class="info-key">Patient <span class="colon"></span></span>
            <span class="info-val" style="font-weight:700">
                @ViewBag.PatientName
            </span>

            <span class="info-key">Department <span class="colon"></span></span>
            <span class="info-val">
                <span class="badge-cms badge-blue">@ViewBag.DepartmentName</span>
            </span>

            <span class="info-key">Doctor <span class="colon"></span></span>
            <span class="info-val" style="font-weight:700">
                Dr. @ViewBag.DoctorName
            </span>

            <span class="info-key">Appointment Date <span class="colon"></span></span>
            <span class="info-val" style="font-weight:700">
                @ViewBag.AppointmentDate
            </span>

            <span class="info-key">Appointment Time <span class="colon"></span></span>
            <span class="info-val" style="font-weight:700">
                @ViewBag.AppointmentTime
            </span>

        </div>
    </div>

    <div class="d-flex justify-content-center gap-3">

        <a asp-controller="Bills"
           asp-action="Create"
           asp-route-appointmentId="@ViewBag.AppointmentId"
           class="btn-primary-cms">
            💳 Go To Billing
        </a>
    </div>

    <div class="tip-bar mt-4" style="text-align:left">
        ℹ Appointment summary includes token number generated for today’s consultation.
    </div>
</div>