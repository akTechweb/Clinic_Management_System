@using InfinityCoderzz_CMSV2026.Models.pharmacist
@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Reports";
    ViewData["ActiveMenu"] = "Reports";

    string report = ViewBag.Report as string ?? "sales";
    string? fromDate = ViewBag.FromDate as string;
    string? toDate = ViewBag.ToDate as string;
    int days = ViewBag.Days ?? 30;

    var reports = new (string Key, string Label, string Icon)[]
    {
        ("sales", "Sales Summary", "fa-chart-line"),
        ("medicinewise", "Medicine-wise Sales", "fa-capsules"),
        ("stock", "Stock Status", "fa-boxes-stacked"),
        ("expiry", "Expiry Report", "fa-clock"),
        ("lowstock", "Low Stock", "fa-triangle-exclamation"),
        ("dispensing", "Dispensing", "fa-hand-holding-medical")
    };

    bool usesDateRange = report is "sales" or "medicinewise" or "dispensing";
    bool usesDays = report is "expiry";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Reports</div>
        <div class="page-sub">Sales, stock, expiry and dispensing analytics</div>
    </div>
    <a asp-action="ExportCsv" asp-route-report="@report" asp-route-fromDate="@fromDate"
       asp-route-toDate="@toDate" asp-route-days="@days" class="btn-primary-cms">
        <i class="fa-solid fa-file-csv"></i> Export CSV
    </a>
</div>

<div class="cms-card mb-3">
    <div class="p-3 d-flex flex-wrap gap-2">
        @foreach (var r in reports)
        {
            <a asp-action="Index" asp-route-report="@r.Key"
               class="@(report == r.Key ? "btn-primary-cms" : "btn-outline-cms") btn-sm-cms">
                <i class="fa-solid @r.Icon"></i> @r.Label
            </a>
        }
    </div>
</div>

@if (usesDateRange || usesDays)
{
    <div class="cms-card mb-3">
        <div class="p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                <input type="hidden" name="report" value="@report" />
                @if (usesDateRange)
                {
                    <div class="col-md-4">
                        <label class="form-label-cms">From Date</label>
                        <input type="date" name="fromDate" value="@fromDate" class="form-control-cms" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label-cms">To Date</label>
                        <input type="date" name="toDate" value="@toDate" class="form-control-cms" />
                    </div>
                }
                @if (usesDays)
                {
                    <div class="col-md-4">
                        <label class="form-label-cms">Within (days)</label>
                        <input type="number" name="days" value="@days" min="1" class="form-control-cms" />
                    </div>
                }
                <div class="col-md-4">
                    <button type="submit" class="btn-primary-cms"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-table"></i> @(reports.First(x => x.Key == report).Label)</span>
    </div>
    <div style="overflow-x:auto;">
        @switch (report)
        {
            case "medicinewise":
                var mw = ViewBag.Data as IEnumerable<MedicineWiseSalesRow> ?? Enumerable.Empty<MedicineWiseSalesRow>();
                <table class="cms-table">
                    <thead><tr><th>Medicine</th><th class="text-center">Qty Sold</th><th class="text-end">Total Amount</th></tr></thead>
                    <tbody>
                        @if (mw.Any())
                        {
                            @foreach (var row in mw)
                            {
                                <tr>
                                    <td style="font-weight:600;">@row.MedicineName</td>
                                    <td class="text-center">@row.QuantitySold</td>
                                    <td class="text-end"><strong class="text-success">₹@row.TotalAmount.ToString("N2")</strong></td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="3" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;

            case "stock":
                var st = ViewBag.Data as IEnumerable<StockStatusRow> ?? Enumerable.Empty<StockStatusRow>();
                <table class="cms-table">
                    <thead><tr><th>Code</th><th>Medicine</th><th class="text-center">Reorder Level</th><th class="text-center">In Stock</th><th>Status</th></tr></thead>
                    <tbody>
                        @if (st.Any())
                        {
                            @foreach (var row in st)
                            {
                                var cls = row.StockStatus == "Out of Stock" ? "badge-danger" : row.StockStatus == "Low" ? "badge-warn" : "badge-success";
                                <tr>
                                    <td>@row.MedicineCode</td>
                                    <td style="font-weight:600;">@row.MedicineName</td>
                                    <td class="text-center">@row.ReorderLevel</td>
                                    <td class="text-center">@row.TotalQuantity</td>
                                    <td><span class="badge-cms @cls">@row.StockStatus</span></td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="5" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;

            case "expiry":
                var ex = ViewBag.Data as IEnumerable<ExpiryReportRow> ?? Enumerable.Empty<ExpiryReportRow>();
                <table class="cms-table">
                    <thead><tr><th>Code</th><th>Medicine</th><th>Batch</th><th class="text-center">Qty</th><th>Expiry Date</th><th class="text-center">Days Left</th><th>Status</th></tr></thead>
                    <tbody>
                        @if (ex.Any())
                        {
                            @foreach (var row in ex)
                            {
                                var cls = row.ExpiryStatus == "Expired" ? "badge-danger" : row.DaysRemaining <= 7 ? "badge-danger" : "badge-warn";
                                <tr>
                                    <td>@row.MedicineCode</td>
                                    <td style="font-weight:600;">@row.MedicineName</td>
                                    <td>@row.BatchNumber</td>
                                    <td class="text-center">@row.Quantity</td>
                                    <td>@row.ExpiryDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-center">@row.DaysRemaining</td>
                                    <td><span class="badge-cms @cls">@row.ExpiryStatus</span></td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="7" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;

            case "lowstock":
                var ls = ViewBag.Data as IEnumerable<LowStockReportRow> ?? Enumerable.Empty<LowStockReportRow>();
                <table class="cms-table">
                    <thead><tr><th>Code</th><th>Medicine</th><th class="text-center">Reorder Level</th><th class="text-center">In Stock</th></tr></thead>
                    <tbody>
                        @if (ls.Any())
                        {
                            @foreach (var row in ls)
                            {
                                <tr>
                                    <td>@row.MedicineCode</td>
                                    <td style="font-weight:600;">@row.MedicineName</td>
                                    <td class="text-center">@row.ReorderLevel</td>
                                    <td class="text-center"><span class="badge-cms badge-danger">@row.TotalQuantity</span></td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="4" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;

            case "dispensing":
                var dp = ViewBag.Data as IEnumerable<DispensingReportRow> ?? Enumerable.Empty<DispensingReportRow>();
                <table class="cms-table">
                    <thead><tr><th>Dispense No.</th><th>Rx No.</th><th>Patient</th><th>Pharmacist</th><th>Date</th><th class="text-center">Items</th><th class="text-end">Total</th></tr></thead>
                    <tbody>
                        @if (dp.Any())
                        {
                            @foreach (var row in dp)
                            {
                                <tr>
                                    <td><strong>@RefNo.Dispense(row.DispenseId)</strong></td>
                                    <td>@RefNo.Rx(row.PrescriptionId)</td>
                                    <td style="font-weight:600;">@row.PatientName</td>
                                    <td>@row.PharmacistName</td>
                                    <td>@row.DispenseDate.ToString("dd MMM yyyy hh:mm tt")</td>
                                    <td class="text-center">@row.TotalItems</td>
                                    <td class="text-end"><strong class="text-success">₹@row.TotalAmount.ToString("N2")</strong></td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="7" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;

            default:
                var ss = ViewBag.Data as IEnumerable<SalesSummaryRow> ?? Enumerable.Empty<SalesSummaryRow>();
                <table class="cms-table">
                    <thead><tr><th>Date</th><th class="text-center">Bills</th><th class="text-center">Items Sold</th><th class="text-end">Total Amount</th></tr></thead>
                    <tbody>
                        @if (ss.Any())
                        {
                            @foreach (var row in ss)
                            {
                                <tr>
                                    <td style="font-weight:600;">@row.SaleDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-center">@row.BillCount</td>
                                    <td class="text-center">@row.ItemsSold</td>
                                    <td class="text-end"><strong class="text-success">₹@row.TotalAmount.ToString("N2")</strong></td>
                                </tr>
                            }
                            <tr style="background:#f8fafc;font-weight:700;">
                                <td class="text-end" colspan="3">GRAND TOTAL</td>
                                <td class="text-end text-success">₹@ss.Sum(x => x.TotalAmount).ToString("N2")</td>
                            </tr>
                        }
                        else { <tr><td colspan="4" class="text-center py-4 text-muted">No data found.</td></tr> }
                    </tbody>
                </table>
                break;
        }
    </div>
</div>
