@using InfinityCoderzz_CMSV2026.Models.pharmacist
@model MedicineStock

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Add Stock";
    ViewData["ActiveMenu"] = "MedicineStock";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="List" class="btn-outline-cms btn-sm-cms">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
    <div>
        <div class="page-title">Add Medicine Stock</div>
        <div class="page-sub">Add a new stock batch</div>
    </div>
</div>

<div class="cms-card" style="max-width:600px;">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-plus"></i> New Stock Batch</span>
    </div>
    <div class="cms-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label-cms">Medicine <span class="req">*</span></label>
                    <select asp-for="MedicineId" asp-items="ViewBag.Medicines" class="form-control-cms">
                        <option value="">-- Select Medicine --</option>
                    </select>
                    <span asp-validation-for="MedicineId" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Batch Number <span class="req">*</span></label>
                    <input asp-for="BatchNumber" class="form-control-cms" maxlength="50"
                           pattern="[A-Za-z0-9/\-]+" autocomplete="off" />
                    <span asp-validation-for="BatchNumber" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Quantity <span class="req">*</span></label>
                    <input asp-for="Quantity" type="number" class="form-control-cms" min="1" max="1000000" step="1" />
                    <span asp-validation-for="Quantity" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Purchase Price (₹) <span class="req">*</span></label>
                    <input asp-for="PurchasePrice" type="number" step="0.01" min="0.01" max="99999999.99" class="form-control-cms" />
                    <span asp-validation-for="PurchasePrice" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Expiry Date <span class="req">*</span></label>
                    <input asp-for="ExpiryDate" type="date" class="form-control-cms" />
                    <span asp-validation-for="ExpiryDate" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Purchase Date</label>
                    <input asp-for="PurchaseDate" type="date" class="form-control-cms" />
                    <span asp-validation-for="PurchaseDate" class="text-danger" style="font-size:12px;"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn-primary-cms">
                    <i class="fa-solid fa-floppy-disk"></i> Save Stock
                </button>
                <a asp-action="List" class="btn-outline-cms">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
