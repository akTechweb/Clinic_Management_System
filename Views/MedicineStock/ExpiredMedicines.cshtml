@model IEnumerable<InfinityCoderzz_CMSV2026.Models.pharmacist.MedicineStock>

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Expired Medicines";
    ViewData["ActiveMenu"] = "Expired";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Expired Medicines</div>
        <div class="page-sub">Medicines that have passed their expiry date</div>
    </div>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title" style="color:#475569;">
            <i class="fa-solid fa-ban"></i> Expired
        </span>
        <span style="font-size:12px;color:#64748b;">@Model.Count() items</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Batch</th>
                    <th>Quantity</th>
                    <th>Expiry Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr class="alert-row">
                            <td style="font-weight:600;">@item.MedicineName</td>
                            <td>@item.BatchNumber</td>
                            <td>@item.Quantity</td>
                            <td style="color:#dc3545;">@item.ExpiryDate.ToString("dd MMM yyyy")</td>
                            <td><span class="badge-cms badge-danger">Expired</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:32px;color:#94a3b8;">
                            No expired medicines
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
