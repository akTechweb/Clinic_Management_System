@model IEnumerable<InfinityCoderzz_CMSV2026.Models.pharmacist.MedicineStock>

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Expiring Medicines";
    ViewData["ActiveMenu"] = "Expiring";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Expiring Medicines</div>
        <div class="page-sub">Medicines expiring within the next 30 days</div>
    </div>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title" style="color:#475569;">
            <i class="fa-solid fa-clock"></i> Expiring Soon
        </span>
        <span style="font-size:12px;color:#64748b;">@Model.Count() items</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Batch</th>
                    <th>Quantity</th>
                    <th>Expiry Date</th>
                    <th>Days Remaining</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="font-weight:600;">@item.MedicineName</td>
                            <td>@item.BatchNumber</td>
                            <td>@item.Quantity</td>
                            <td>@item.ExpiryDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge-cms badge-warn">
                                    @item.DaysRemaining days
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:32px;color:#94a3b8;">
                            <i class="fa-solid fa-circle-check" style="font-size:28px;display:block;margin-bottom:8px;color:#198754;"></i>
                            No medicines expiring soon
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
