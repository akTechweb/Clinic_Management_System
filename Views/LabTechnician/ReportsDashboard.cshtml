@model List<InfinityCoderzz_CMSV2026.Models.CompletedLabReportViewModel>
@{
    Layout = "_LabLayout";
    ViewData["Title"] = "Reports Dashboard";
    ViewData["ActiveMenu"] = "ReportsDashboard";
}

<h2 style="color:#0f172a; font-size:22px; font-weight:700; margin-bottom:18px;">
    <i class="fa-solid fa-file-medical"></i> Lab Reports Dashboard
</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#dcfce7; color:#15803d; padding:12px 16px; border-radius:10px; margin-bottom:16px; font-size:13px; font-weight:600;">
        <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div style="background:#fee2e2; color:#dc2626; padding:12px 16px; border-radius:10px; margin-bottom:16px; font-size:13px; font-weight:600;">
        <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
    </div>
}

<div style="background:white; padding:18px; border-radius:12px; border:1px solid #e2e8f0; margin-bottom:20px;">
    <form asp-action="ReportsDashboard" method="get" style="display:flex; gap:10px; align-items:center;">
        <input type="text" name="searchMMR" class="form-control"
               style="flex:1; padding:11px 14px; margin-top:0;"
               placeholder="Search by Patient MMR Code..."
               value="@ViewBag.SearchMMR" />
        <button type="submit" class="btn-custom" style="padding:11px 24px;">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchMMR as string))
        {
            <a asp-action="ReportsDashboard" class="btn-custom" style="background:#64748b; padding:11px 18px;">
                <i class="fa-solid fa-xmark"></i> Clear
            </a>
        }
    </form>
</div>

<div style="background:white; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.04);">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
            <tr style="background:#f8fafc; color:#475569; border-bottom:2px solid #e2e8f0;">
                <th style="padding:14px 16px;">MMR Code</th>
                <th style="padding:14px 16px;">Patient Name</th>
                <th style="padding:14px 16px;">Test Name</th>
                <th style="padding:14px 16px;">Result</th>
                <th style="padding:14px 16px;">Status</th>
                <th style="padding:14px 16px;">Result Date</th>
                <th style="padding:14px 16px;">Doctor</th>
                <th style="padding:14px 16px;">Technician</th>
                <th style="padding:14px 16px; text-align:center;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="9" style="padding:40px; text-align:center; color:#94a3b8; font-weight:500;">
                        <i class="fa-solid fa-flask-vial fa-2x" style="display:block; margin-bottom:10px; opacity:0.4;"></i>
                        No completed lab reports found.
                    </td>
                </tr>
            }
            else
            {
                foreach (var r in Model)
                {
                    string rowBg = r.IsAbnormal ? "#fff1f2" : "";
                    <tr style="border-bottom:1px solid #f1f5f9; background:@rowBg;">
                        <td style="padding:14px 16px; color:#2563eb; font-weight:600;">@r.MMRCode</td>
                        <td style="padding:14px 16px; font-weight:600; color:#1e293b;">@r.PatientName</td>
                        <td style="padding:14px 16px; font-weight:600; color:#1e3a8a;">@r.TestName</td>
                        <td style="padding:14px 16px; font-weight:700; color:@(r.IsAbnormal ? "#dc2626" : "#16a34a");">
                            @r.ResultValue
                        </td>
                        <td style="padding:14px 16px;">
                            @if (r.IsAbnormal)
                            {
                                <span style="padding:4px 10px; border-radius:12px; font-size:11px; font-weight:700; background:#fee2e2; color:#dc2626;">ABNORMAL</span>
                            }
                            else
                            {
                                <span style="padding:4px 10px; border-radius:12px; font-size:11px; font-weight:700; background:#dcfce7; color:#15803d;">Normal</span>
                            }
                        </td>
                        <td style="padding:14px 16px; color:#64748b;">@r.ResultDate.ToString("dd-MM-yyyy HH:mm")</td>
                        <td style="padding:14px 16px; color:#475569; font-size:13px;">Dr. @r.DoctorName</td>
                        <td style="padding:14px 16px; color:#475569; font-size:13px;">@r.TechnicianName</td>
                        <td style="padding:14px 16px; text-align:center;">
                            <div style="display:flex; gap:6px; justify-content:center;">
                                <a href="/LabTechnician/DownloadReportPdf?resultId=@r.ResultId" target="_blank"
                                   class="btn-custom" style="padding:6px 12px; font-size:12px; background:#e11d48;">
                                    <i class="fa-solid fa-file-pdf"></i> PDF
                                </a>
                                <form asp-action="ResendEmail" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="resultId" value="@r.ResultId" />
                                    <input type="hidden" name="searchMMR" value="@ViewBag.SearchMMR" />
                                    <button type="submit" class="btn-custom" style="padding:6px 12px; font-size:12px; background:linear-gradient(135deg,#3b82f6,#0ea5e9);">
                                        <i class="fa-solid fa-paper-plane"></i> Email
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>