@model InfinityCoderzz_CMSV2026.Models.LabDashboardStatsViewModel
@{
    Layout = "_LabLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "Dashboard";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:28px;">
    <div>
        <h1 style="color:#0f172a; font-size:26px; font-weight:700;">Welcome , @ViewBag.TechnicianName 🧪</h1>
        <p style="color:#64748b; margin-top:5px;">Manage lab test requests, results, reports and billing.</p>
    </div>
    <div style="background:#dbeafe; padding:12px 20px; border-radius:12px; color:#0369a1; font-weight:700;">
        Lab Technician Dashboard
    </div>
</div>

<!-- Stats -->
<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-bottom:28px;">
    <div style="background:linear-gradient(135deg,#3b82f6,#0ea5e9); padding:24px; border-radius:18px; color:white;">
        <i class="fa-solid fa-clipboard-list fa-2x"></i>
        <div style="font-size:34px; font-weight:700; margin:8px 0 4px;">@Model.TotalRequests</div>
        <div style="font-size:14px; opacity:0.9;">Total Requests</div>
    </div>
    <div style="background:linear-gradient(135deg,#10b981,#059669); padding:24px; border-radius:18px; color:white;">
        <i class="fa-solid fa-hourglass-half fa-2x"></i>
        <div style="font-size:34px; font-weight:700; margin:8px 0 4px;">@Model.PendingTests</div>
        <div style="font-size:14px; opacity:0.9;">Pending Tests</div>
    </div>
    <div style="background:linear-gradient(135deg,#a855f7,#7c3aed); padding:24px; border-radius:18px; color:white;">
        <i class="fa-solid fa-file-circle-check fa-2x"></i>
        <div style="font-size:34px; font-weight:700; margin:8px 0 4px;">@Model.CompletedReports</div>
        <div style="font-size:14px; opacity:0.9;">Completed Reports</div>
    </div>
</div>

<!-- Quick Actions -->
<div style="background:white; padding:28px; border-radius:18px; border:1px solid #e2e8f0; text-align:center;">
    <h3 style="color:#1e293b; margin-bottom:20px;">Quick Access</h3>
    <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <a asp-action="PendingTests" class="btn-custom" style="padding:14px 28px;">
            <i class="fa-solid fa-vial-circle-check"></i> Pending Tests
        </a>
        <a asp-action="ReportsDashboard" class="btn-custom" style="background:linear-gradient(135deg,#10b981,#059669); padding:14px 28px;">
            <i class="fa-solid fa-file-medical"></i> Reports Dashboard
        </a>
        <a asp-action="BillingDashboard" class="btn-custom" style="background:linear-gradient(135deg,#a855f7,#7c3aed); padding:14px 28px;">
            <i class="fa-solid fa-receipt"></i> Billing Dashboard
        </a>
    </div>
</div>