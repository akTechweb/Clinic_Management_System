@model List<InfinityCoderzz_CMSV2026.Models.UnbilledLabRequestViewModel>
@{
    Layout = "_LabLayout";
    ViewData["Title"] = "Billing Dashboard";
    ViewData["ActiveMenu"] = "BillingDashboard";
    var bills = ViewBag.Bills as List<InfinityCoderzz_CMSV2026.Models.LabBillViewModel>;
}

<h2 style="color:#0f172a; font-size:22px; font-weight:700; margin-bottom:18px;">
    <i class="fa-solid fa-receipt"></i> Lab Billing Dashboard
</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#dcfce7; color:#15803d; padding:12px 16px; border-radius:10px; margin-bottom:16px; font-size:13px; font-weight:600;">
        <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
    </div>
}

<div style="background:white; padding:18px; border-radius:12px; border:1px solid #e2e8f0; margin-bottom:20px;">
    <form asp-action="BillingDashboard" method="get" style="display:flex; gap:10px; align-items:center;">
        <input type="text" name="searchMMR" class="form-control"
               style="flex:1; padding:11px 14px; margin-top:0;"
               placeholder="Search by Patient MMR Code..."
               value="@ViewBag.SearchMMR" />
        <button type="submit" class="btn-custom" style="padding:11px 24px;">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchMMR as string))
        {
            <a asp-action="BillingDashboard" class="btn-custom" style="background:#64748b; padding:11px 18px;">
                <i class="fa-solid fa-xmark"></i> Clear
            </a>
        }
    </form>
</div>

<h3 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:10px;">
    <i class="fa-solid fa-list-check"></i> Requests Ready for Billing
</h3>
<div style="background:white; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.04); margin-bottom:28px;">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
            <tr style="background:#f8fafc; color:#475569; border-bottom:2px solid #e2e8f0;">
                <th style="padding:14px 16px;">MMR Code</th>
                <th style="padding:14px 16px;">Patient Name</th>
                <th style="padding:14px 16px;">Mobile</th>
                <th style="padding:14px 16px;">Tests</th>
                <th style="padding:14px 16px;">Total Amount</th>
                <th style="padding:14px 16px;">Request Date</th>
                <th style="padding:14px 16px; text-align:center;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr><td colspan="7" style="padding:30px; text-align:center; color:#94a3b8; font-weight:500;">No requests pending for billing.</td></tr>
            }
            else
            {
                foreach (var u in Model)
                {
                    <tr style="border-bottom:1px solid #f1f5f9;">
                        <td style="padding:14px 16px; color:#2563eb; font-weight:600;">@u.MMRCode</td>
                        <td style="padding:14px 16px; font-weight:600; color:#1e293b;">@u.PatientName</td>
                        <td style="padding:14px 16px; color:#64748b;">@u.MobileNumber</td>
                        <td style="padding:14px 16px; color:#475569;">@u.TotalTests</td>
                        <td style="padding:14px 16px; font-weight:700; color:#15803d;">₹@u.TotalAmount.ToString("0.00")</td>
                        <td style="padding:14px 16px; color:#64748b;">@u.RequestDate.ToString("dd-MM-yyyy")</td>
                        <td style="padding:14px 16px; text-align:center;">
                            <form asp-action="GenerateBill" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@u.RequestId" />
                                <input type="hidden" name="searchMMR" value="@ViewBag.SearchMMR" />
                                <button type="submit" class="btn-custom" style="padding:7px 14px; font-size:13px; background:linear-gradient(135deg,#a855f7,#7c3aed);">
                                    <i class="fa-solid fa-file-invoice-dollar"></i> Generate Bill
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<h3 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:10px;">
    <i class="fa-solid fa-file-invoice"></i> Generated Bills
</h3>
<div style="background:white; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.04);">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
            <tr style="background:#f8fafc; color:#475569; border-bottom:2px solid #e2e8f0;">
                <th style="padding:14px 16px;">Bill ID</th>
                <th style="padding:14px 16px;">MMR Code</th>
                <th style="padding:14px 16px;">Patient Name</th>
                <th style="padding:14px 16px;">Bill Date</th>
                <th style="padding:14px 16px;">Amount</th>
                <th style="padding:14px 16px;">Payment Status</th>
                <th style="padding:14px 16px; text-align:center;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (bills == null || bills.Count == 0)
            {
                <tr><td colspan="7" style="padding:30px; text-align:center; color:#94a3b8; font-weight:500;">No bills generated yet.</td></tr>
            }
            else
            {
                foreach (var b in bills)
                {
                    var bg = b.PaymentStatus == "Paid" ? "#dcfce7" : "#fef3c7";
                    var fg = b.PaymentStatus == "Paid" ? "#15803d" : "#b45309";
                    <tr style="border-bottom:1px solid #f1f5f9;">
                        <td style="padding:14px 16px; font-weight:700; color:#0f172a;">#@b.BillId</td>
                        <td style="padding:14px 16px; color:#2563eb; font-weight:600;">@b.MMRCode</td>
                        <td style="padding:14px 16px; font-weight:600; color:#1e293b;">@b.PatientName</td>
                        <td style="padding:14px 16px; color:#64748b;">@b.BillDate.ToString("dd-MM-yyyy HH:mm")</td>
                        <td style="padding:14px 16px; font-weight:700; color:#15803d;">₹@b.TotalAmount.ToString("0.00")</td>
                        <td style="padding:14px 16px;">
                            <span style="padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600; background:@bg; color:@fg;">@b.PaymentStatus</span>
                        </td>
                        <td style="padding:14px 16px; text-align:center;">
                            <div style="display:flex; gap:6px; justify-content:center;">
                                <a href="/LabTechnician/DownloadBillPdf?billId=@b.BillId"
                                   class="btn-custom" style="padding:6px 12px; font-size:12px; background:#e11d48;">
                                    <i class="fa-solid fa-file-pdf"></i> Download PDF
                                </a>
                                <a href="/LabTechnician/PrintBill?billId=@b.BillId" target="_blank"
                                   class="btn-custom" style="padding:6px 12px; font-size:12px; background:#64748b;">
                                    <i class="fa-solid fa-print"></i> Print
                                </a>
                                @if (b.PaymentStatus != "Paid")
                                {
                                    <form asp-action="UpdateBillPayment" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="billId" value="@b.BillId" />
                                        <input type="hidden" name="paymentStatus" value="Paid" />
                                        <input type="hidden" name="searchMMR" value="@ViewBag.SearchMMR" />
                                        <button type="submit" class="btn-custom" style="padding:6px 12px; font-size:12px; background:linear-gradient(135deg,#16a34a,#15803d);">
                                            <i class="fa-solid fa-check"></i> Mark Paid
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>