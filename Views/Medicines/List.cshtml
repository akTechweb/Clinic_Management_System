@using InfinityCoderzz_CMSV2026.Models
@using InfinityCoderzz_CMSV2026.Models.pharmacist

@model IEnumerable<Medicine>

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Medicines";
    ViewData["ActiveMenu"] = "Medicines";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Medicines</div>
        <div class="page-sub">Manage your medicine catalogue</div>
    </div>
    <a asp-action="Create" class="btn-primary-cms">
        <i class="fa-solid fa-plus"></i> Add Medicine
    </a>
</div>

<div class="cms-card mb-3">
    <div class="cms-card-body">
        <form asp-action="List" method="get" class="d-flex gap-2">
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                   class="form-control-cms" style="max-width:320px;"
                   placeholder="Search by name or code..." />
            <button type="submit" class="btn-primary-cms">
                <i class="fa-solid fa-magnifying-glass"></i> Search
            </button>
            @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
            {
                <a asp-action="List" class="btn-outline-cms">Clear</a>
            }
        </form>
    </div>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-capsules"></i> Medicine Catalogue</span>
        <span style="font-size:12px;color:#64748b;">@Model.Count() medicines</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Medicine Name</th>
                    <th>Generic Name</th>
                    <th>Category</th>
                    <th>Manufacturer</th>
                    <th>Unit</th>
                    <th>Unit Price</th>
                    <th>Reorder Lvl</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="font-size:12px;color:#64748b;">@item.MedicineCode</td>
                            <td style="font-weight:600;">@item.MedicineName</td>
                            <td>@item.GenericName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.ManufacturerName</td>
                            <td>@item.Unit</td>
                            <td style="font-weight:600;color:#198754;">₹@item.UnitPrice</td>
                            <td>@item.ReorderLevel</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-cms badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge-cms badge-gray">Disabled</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.MedicineId"
                                       class="btn-outline-cms btn-sm-cms">
                                        <i class="fa-solid fa-pen"></i> Edit
                                    </a>
                                    <form asp-action="Disable" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.MedicineId" />
                                        <button type="submit" class="btn-danger-cms btn-sm-cms"
                                                onclick="return confirm('Disable this medicine?');">
                                            <i class="fa-solid fa-ban"></i> Disable
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" style="text-align:center;padding:32px;color:#94a3b8;">
                            <i class="fa-solid fa-capsules" style="font-size:28px;display:block;margin-bottom:8px;"></i>
                            No medicines found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
