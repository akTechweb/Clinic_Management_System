@using InfinityCoderzz_CMSV2026.Models
@using InfinityCoderzz_CMSV2026.Models.pharmacist
@model Medicine

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Add Medicine";
    ViewData["ActiveMenu"] = "Medicines";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="List" class="btn-outline-cms btn-sm-cms">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
    <div>
        <div class="page-title">Add Medicine</div>
        <div class="page-sub">Register a new medicine in the catalogue</div>
    </div>
</div>

<div class="cms-card" style="max-width:680px;">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-plus"></i> New Medicine</span>
    </div>
    <div class="cms-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label-cms">Medicine Code</label>
                    <input name="MedicineCode" value="@Model?.MedicineCode" class="form-control-cms" placeholder="Auto-generated (e.g. MED-000123)" />
                    <span asp-validation-for="MedicineCode" class="text-danger" style="font-size:12px;"></span>
                    <div style="font-size:11px;color:#94a3b8;margin-top:4px;">Auto-generated &mdash; you can edit it, or clear it to let the system assign the next code.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Medicine Name <span class="req">*</span></label>
                    <input asp-for="MedicineName" class="form-control-cms" />
                    <span asp-validation-for="MedicineName" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Generic Name</label>
                    <input asp-for="GenericName" class="form-control-cms" />
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Unit</label>
                    <input asp-for="Unit" class="form-control-cms" placeholder="e.g. Tablet, Syrup" />
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Category <span class="req">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control-cms">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Manufacturer <span class="req">*</span></label>
                    <select asp-for="ManufacturerId" asp-items="ViewBag.Manufacturers" class="form-control-cms">
                        <option value="">-- Select Manufacturer --</option>
                    </select>
                    <span asp-validation-for="ManufacturerId" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Unit Price (₹) <span class="req">*</span></label>
                    <input asp-for="UnitPrice" class="form-control-cms" type="number" step="0.01" />
                    <span asp-validation-for="UnitPrice" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-cms">Reorder Level <span class="req">*</span></label>
                    <input asp-for="ReorderLevel" class="form-control-cms" type="number" />
                    <span asp-validation-for="ReorderLevel" class="text-danger" style="font-size:12px;"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn-primary-cms">
                    <i class="fa-solid fa-floppy-disk"></i> Save Medicine
                </button>
                <a asp-action="List" class="btn-outline-cms">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
