@model IEnumerable<InfinityCoderzz_CMSV2026.Models.PatientVisit>
@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Visit History";
    ViewData["ActiveNav"] = "Records";
    ViewData["ShowTopbarInfo"] = true;
    var list = Model?.ToList() ?? new();
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="page-title">Patient Visit History</h4>
        <p class="page-sub">All patient consultation visit records</p>
    </div>
</div>

<div class="cms-card">
    <div style="overflow-x:auto">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Token</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Department</th>
                    <th>Visit Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (list.Any())
                {
                    int i = 1;
                    foreach (var v in list)
                    {
                        <tr>
                            <td>@i</td>
                            <td><span class="token-chip">T@(v.TokenNumber.ToString().PadLeft(3, '0'))</span></td>
                            <td><strong>@v.PatientName</strong></td>
                            <td>Dr. @v.DoctorName</td>
                            <td><span class="badge-cms badge-blue">@v.DepartmentName</span></td>
                            <td>@(v.VisitDate.HasValue? v.VisitDate.Value.ToString("dd MMM yyyy") : "—")</td>
                            <td>
                                @switch (v.VisitStatus)
                                {
                                    case "Completed":
                                        <span class="badge-cms badge-success">Completed</span>
                                        break;
                                    case "In Progress":

                                        <span class="badge-cms badge-warn">In Progress</span>
                                        break;
                                    case "Cancelled":

                                        <span class="badge-cms badge-danger">Cancelled</span>
                                        break;
                                    default:

                                        <span class="badge-cms badge-gray">@v.VisitStatus</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@v.VisitId"
                                   class="btn-outline-cms btn-sm-cms">View</a>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <div class="ei">🕐</div>
                                <p>No visit records found.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
