@model InfinityCoderzz_CMSV2026.Models.Patient

@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Edit Patient";
    ViewData["ActiveNav"] = "Records";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="page-title">Edit Patient</h4>
        <p class="page-sub">
            <span style="color:var(--blue);font-weight:600">@Model.PatientCode</span> — @Model.FullName
        </p>
    </div>

    <a asp-action="Details" asp-route-id="@Model.PatientId" class="btn-outline-cms">
        ← Back to Details
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="cms-alert cms-alert-danger">⚠ @TempData["ErrorMessage"]</div>
}

<form asp-controller="Patients" asp-action="Edit" method="post" id="editForm" style="max-width:760px" novalidate>
    <input type="hidden" asp-for="PatientId" />
    <input type="hidden" asp-for="PatientCode" />

    <div class="cms-card mb-4">
        <div class="cms-card-header">
            <span class="cms-card-title">👤 Personal Information</span>
        </div>

        <div class="cms-card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label-cms">MMR No</label>
                    <input class="form-control-cms readonly-field" value="@Model.PatientCode" readonly />
                </div>

                <div class="col-12">
                    <label class="form-label-cms">Full Name <span class="req">*</span></label>
                    <input asp-for="FullName" class="form-control-cms" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label-cms">Gender <span class="req">*</span></label>

                    <div class="gender-wrap">
                        <label class="gender-radio">
                            <input asp-for="Gender" type="radio" value="Male" />
                            <span>Male</span>
                        </label>

                        <label class="gender-radio">
                            <input asp-for="Gender" type="radio" value="Female" />
                            <span>Female</span>
                        </label>

                        <label class="gender-radio">
                            <input asp-for="Gender" type="radio" value="Other" />
                            <span>Other</span>
                        </label>
                    </div>

                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="col-md-5">
                    <label class="form-label-cms">Date of Birth</label>
                    <input asp-for="DOB" type="date" class="form-control-cms" id="dobField"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DOB" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label-cms">Age</label>
                    <div class="input-group-cms">
                        <input type="text" class="form-control-cms readonly-field" id="ageDisplay"
                               value="@(Model.Age?.ToString() ?? "0")" readonly />
                        <span class="prefix" style="border-left:none;border-radius:0 8px 8px 0;border:1.5px solid var(--border)">Years</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label-cms">Blood Group</label>
                    <select asp-for="BloodGroup" class="form-control-cms">
                        <option value="">Select Blood Group</option>
                        <option>A+</option>
                        <option>A-</option>
                        <option>B+</option>
                        <option>B-</option>
                        <option>O+</option>
                        <option>O-</option>
                        <option>AB+</option>
                        <option>AB-</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="cms-card mb-4">
        <div class="cms-card-header">
            <span class="cms-card-title">📞 Contact Information</span>
        </div>

        <div class="cms-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label-cms">Mobile Number <span class="req">*</span></label>
                    <input asp-for="MobileNumber" class="form-control-cms" maxlength="10" required />
                    <span asp-validation-for="MobileNumber" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label-cms">Email</label>
                    <input asp-for="Email" type="email" class="form-control-cms" />
                </div>

                <div class="col-md-6">
                    <label class="form-label-cms">Emergency Contact Number</label>
                    <input asp-for="EmergencyContactNumber" class="form-control-cms" maxlength="10" />
                    <span asp-validation-for="EmergencyContactNumber" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label-cms">Address</label>
                    <textarea asp-for="Address" class="form-control-cms" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3">
        <button type="submit" class="btn-success-cms">
            💾 Save Changes
        </button>

        <a asp-action="Details" asp-route-id="@Model.PatientId" class="btn-danger-cms">
            ✖ Cancel
        </a>
    </div>
</form>

@section Scripts {
    <script>
        const dob = document.getElementById('dobField');
        const age = document.getElementById('ageDisplay');

        function calcAge() {
            if (!dob.value) {
                age.value = '0';
                return;
            }

            const d = new Date(dob.value);
            const t = new Date();

            let a = t.getFullYear() - d.getFullYear();

            if (t.getMonth() - d.getMonth() < 0 ||
                (t.getMonth() === d.getMonth() && t.getDate() < d.getDate())) {
                a--;
            }

            age.value = a >= 0 ? a : '0';
        }

        dob.addEventListener('change', calcAge);
        dob.addEventListener('input', calcAge);

        document.querySelectorAll('[name="MobileNumber"],[name="EmergencyContactNumber"]').forEach(function (el) {
            el.addEventListener('input', function () {
                this.value = this.value.replace(/\D/g, '');
            });
        });

        if (dob.value) calcAge();
    </script>
}