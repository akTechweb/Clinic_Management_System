@model InfinityCoderzz_CMSV2026.Models.Patient
@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Patient Details";
    ViewData["ActiveNav"] = "Records";
    ViewData["ShowTopbarInfo"] = true;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="page-title">Patient Details</h4>
        <p class="page-sub"><span style="color:var(--blue);font-weight:600">@Model.PatientCode</span> — @Model.FullName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Search" class="btn-outline-cms">← Back</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="cms-alert cms-alert-success">✓ @TempData["SuccessMessage"]</div>
}

<div class="row g-3">
    <!-- Personal info -->
    <div class="col-md-5">
        <div class="cms-card h-100">
            <div class="cms-card-header"><span class="cms-card-title">👤 Personal Information</span></div>
            <div class="cms-card-body">
                <div class="info-grid">
                    <span class="info-key">MMR No <span class="colon"></span></span>
                    <span class="info-val" style="color:var(--blue)">@Model.PatientCode</span>

                    <span class="info-key">Full Name <span class="colon"></span></span>
                    <span class="info-val" style="font-weight:700">@Model.FullName</span>

                    <span class="info-key">Gender <span class="colon"></span></span>
                    <span class="info-val">
                        @if (Model.Gender == "Male")
                        {
                            <span>♂ Male</span>
                        }
                        else if (Model.Gender == "Female")
                        {

                            <span>♀ Female</span>
                        }
                        else
                        {

                            <span>@(Model.Gender ?? "—")</span>
                        }
                    </span>

                    <span class="info-key">Date of Birth <span class="colon"></span></span>
                    <span class="info-val">@(Model.DOB.HasValue? Model.DOB.Value.ToString("dd-MM-yyyy") : "—")</span>

                    <span class="info-key">Age <span class="colon"></span></span>
                    <span class="info-val">
                        @if (Model.Age.HasValue)
                        {
                            <span class="badge-cms badge-blue">@Model.Age Years</span>
                        }
                        else
                        {

                            <span>—</span>
                        }
                    </span>

                    <span class="info-key">Blood Group <span class="colon"></span></span>
                    <span class="info-val">
                        @if (!string.IsNullOrEmpty(Model.BloodGroup))
                        {
                            <span class="badge-cms badge-danger">@Model.BloodGroup</span>
                        }
                        else
                        {

                            <span>—</span>
                        }
                    </span>

                    <span class="info-key">Status <span class="colon"></span></span>
                    <span class="info-val">
                        @if (Model.IsActive)
                        {
                            <span class="badge-cms badge-success">Active</span>
                        }
                        else
                        {

                            <span class="badge-cms badge-gray">Inactive</span>
                        }
                    </span>

                    <span class="info-key">Registered On <span class="colon"></span></span>
                    <span class="info-val">@(Model.RegistrationDate.HasValue? Model.RegistrationDate.Value.ToString("dd MMM yyyy") : "—")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact -->
    <div class="col-md-4">
        <div class="cms-card h-100">
            <div class="cms-card-header"><span class="cms-card-title">📞 Contact Information</span></div>
            <div class="cms-card-body">
                <div class="info-grid">
                    <span class="info-key">Mobile <span class="colon"></span></span>
                    <span class="info-val">@(Model.MobileNumber ?? "—")</span>

                    <span class="info-key">Email <span class="colon"></span></span>
                    <span class="info-val" style="word-break:break-all">@(Model.Email ?? "—")</span>

                    <span class="info-key">Emergency <span class="colon"></span></span>
                    <span class="info-val">@(Model.EmergencyContactNumber ?? "—")</span>

                    <span class="info-key">Address <span class="colon"></span></span>
                    <span class="info-val">@(Model.Address ?? "—")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick actions -->
    <div class="col-md-3">
        <div class="cms-card">
            <div class="cms-card-header"><span class="cms-card-title">⚡ Quick Actions</span></div>
            <div class="cms-card-body d-flex flex-column gap-2">
                <a asp-controller="Appointments" asp-action="Create"
                   asp-route-patientId="@Model.PatientId"
                   class="btn-success-cms" style="justify-content:center">📅 Make Appointment</a>
                <a asp-controller="Patients"
                   asp-action="Edit"
                   asp-route-id="@Model.PatientId"
                   class="btn-outline-cms"
                   style="justify-content:center">
                    ✏ Edit Patient
                </a>
                <a asp-controller="PatientVisits" asp-action="Index"
                   asp-route-patientId="@Model.PatientId"
                   class="btn-outline-cms" style="justify-content:center">🕐 Visit History</a>
                <a asp-controller="Bills" asp-action="Index"
                   asp-route-patientId="@Model.PatientId"
                   class="btn-outline-cms" style="justify-content:center">🧾 View Bills</a>
            </div>
        </div>
    </div>
</div>
