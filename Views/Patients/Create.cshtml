@model InfinityCoderzz_CMSV2026.Models.Patient

@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";

    ViewData["Title"] = "Register New Patient";
    ViewData["ActiveNav"] = "Register";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="page-title">Register New Patient</h4>
        <p class="page-sub">
            Enter patient details to create a new patient record.
        </p>
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="cms-alert cms-alert-danger">
                ⚠ @TempData["ErrorMessage"]
            </div>
        }
    </div>


    <a asp-controller="Receptionists"
       asp-action="Dashboard"
       class="btn-outline-cms">
        ← Back to Dashboard
    </a>
</div>

<form asp-controller="Patients"
      asp-action="Create" method="post"
      id="regForm" style="max-width:850px"
      novalidate>

    <div class="cms-card mb-4">
        <div class="cms-card-header">
            <span class="cms-card-title">👤 Patient Information</span>
        </div>

        <div class="cms-card-body">

            <!-- MMR Number -->
            <div class="mb-3">
                <label class="form-label-cms">MMR Number</label>

                <input class="form-control-cms readonly-field"
                       value="@ViewBag.GeneratedMMR"
                       readonly />

                <small class="text-muted">
                    MMR Number will be generated automatically when saved.
                </small>
            </div>

            <!-- Full Name -->
            <div class="mb-3">
                <label class="form-label-cms">
                    Full Name <span class="req">*</span>
                </label>

                <input asp-for="FullName"
                       class="form-control-cms"
                       placeholder="Enter patient full name"
                       required />

                <span asp-validation-for="FullName"
                      class="text-danger"></span>
            </div>

            <!-- Gender -->
            <div class="mb-3">
                <label class="form-label-cms">
                    Gender <span class="req">*</span>
                </label>

                <div class="gender-wrap">

                    <label class="gender-radio">
                        <input type="radio"
                               asp-for="Gender"
                               value="Male"
                               required />
                        <span>Male</span>
                    </label>

                    <label class="gender-radio">
                        <input type="radio"
                               asp-for="Gender"
                               value="Female" />
                        <span>Female</span>
                    </label>

                    <label class="gender-radio">
                        <input type="radio"
                               asp-for="Gender"
                               value="Other" />
                        <span>Other</span>
                    </label>

                </div>

                <span asp-validation-for="Gender"
                      class="text-danger"></span>
            </div>

            <!-- DOB + Age + Blood Group -->
            <div class="row g-3 mb-3">

                <div class="col-md-5">
                    <label class="form-label-cms">
                        Date of Birth
                    </label>

                    <input asp-for="DOB"
                           id="dobField"
                           type="date"
                           class="form-control-cms"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />

                    <span asp-validation-for="DOB"
                          class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label-cms">
                        Age
                    </label>

                    <div class="input-group-cms">
                        <input type="text"
                               id="ageDisplay"
                               class="form-control-cms readonly-field"
                               value="0"
                               readonly />

                        <span class="prefix"
                              style="border-left:none;border-radius:0 8px 8px 0;border:1px solid var(--border)">
                            Years
                        </span>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label-cms">
                        Blood Group
                    </label>

                    <select asp-for="BloodGroup"
                            class="form-control-cms">

                        <option value="Unknown">Unknown</option>
                        <option>A+</option>
                        <option>A-</option>
                        <option>B+</option>
                        <option>B-</option>
                        <option>O+</option>
                        <option>O-</option>
                        <option>AB+</option>
                        <option>AB-</option>

                    </select>
                </div>

            </div>

        </div>
    </div>

    <!-- Contact Information -->
    <div class="cms-card mb-4">

        <div class="cms-card-header">
            <span class="cms-card-title">📞 Contact Information</span>
        </div>

        <div class="cms-card-body">

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label-cms">
                        Mobile Number <span class="req">*</span>
                    </label>

                    <input asp-for="MobileNumber"
                           class="form-control-cms"
                           maxlength="10"
                           minlength="10"
                           pattern="[0-9]{10}"
                           required
                           placeholder="Enter 10 digit mobile number" />

                    <span asp-validation-for="MobileNumber"
                          class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label-cms">
                        Email
                    </label>

                    <input asp-for="Email"
                           type="email"
                           class="form-control-cms"
                           placeholder="Enter email address" />
                </div>

                <div class="col-md-6">
                    <label class="form-label-cms">
                        Emergency Contact Number
                    </label>

                    <input asp-for="EmergencyContactNumber"
                           class="form-control-cms"
                           maxlength="10"
                           pattern="[0-9]{10}"
                           placeholder="Enter emergency contact number" />

                    <span asp-validation-for="EmergencyContactNumber"
                          class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label-cms">
                        Address
                    </label>

                    <textarea asp-for="Address"
                              rows="3"
                              class="form-control-cms"
                              placeholder="Enter address">
                    </textarea>
                </div>

            </div>

        </div>
    </div>

    <div class="d-flex gap-3">

        <button type="submit"
                class="btn-success-cms">
            💾 Register Patient
        </button>

        <button type="button"
                class="btn-warn-cms"
                onclick="clearForm()">
            ✋ Clear
        </button>

        <a asp-controller="Receptionists"
           asp-action="Dashboard"
           class="btn-danger-cms">
            ✖ Cancel
        </a>

    </div>

</form>

@section Scripts {

    <script>

        const dob = document.getElementById('dobField');
        const age = document.getElementById('ageDisplay');

        function calculateAge()
        {
            if (!dob.value)
            {
                age.value = '0';
                return;
            }

            const birthDate = new Date(dob.value);
            const today = new Date();

            let years = today.getFullYear() - birthDate.getFullYear();

            if (
                today.getMonth() < birthDate.getMonth() ||
                (
                    today.getMonth() === birthDate.getMonth() &&
                    today.getDate() < birthDate.getDate()
                )
            )
            {
                years--;
            }

            age.value = years < 0 ? 0 : years;
        }

        dob.addEventListener('change', calculateAge);
        dob.addEventListener('input', calculateAge);

        function clearForm()
        {
            document.getElementById('regForm').reset();
            age.value = '0';
        }

        document.querySelectorAll(
        '[name="MobileNumber"],[name="EmergencyContactNumber"]'
        ).forEach(function(control)
        {
            control.addEventListener('input', function()
            {
                this.value = this.value.replace(/\D/g,'');
            });
        });

    </script>

}