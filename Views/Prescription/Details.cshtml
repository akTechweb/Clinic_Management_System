@model InfinityCoderzz_CMSV2026.Models.pharmacist.Prescription

@{
    Layout = "_PharmacyLayout";
    ViewData["Title"] = "Prescription Details";
    ViewData["ActiveMenu"] = "Prescriptions";
    var items = ViewBag.Items as IEnumerable<InfinityCoderzz_CMSV2026.Models.pharmacist.PrescriptionItem>
                ?? Enumerable.Empty<InfinityCoderzz_CMSV2026.Models.pharmacist.PrescriptionItem>();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="List" class="btn-outline-cms btn-sm-cms">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
    <div>
        <div class="page-title">Prescription @RefNo.Rx(Model.PrescriptionId)</div>
        <div class="page-sub">Issued on @Model.PrescriptionDate.ToString("dd MMM yyyy")</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="cms-card">
            <div class="cms-card-header">
                <span class="cms-card-title"><i class="fa-solid fa-user"></i> Patient Info</span>
            </div>
            <div class="cms-card-body">
                <table style="font-size:13px;width:100%;border-collapse:collapse;">
                    <tr>
                        <td style="color:#64748b;padding:5px 0;width:120px;">Patient Name</td>
                        <td style="font-weight:600;">@Model.PatientName</td>
                    </tr>
                    <tr>
                        <td style="color:#64748b;padding:5px 0;">Doctor</td>
                        <td>@Model.DoctorName</td>
                    </tr>
                    <tr>
                        <td style="color:#64748b;padding:5px 0;">Date</td>
                        <td>@Model.PrescriptionDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td style="color:#64748b;padding:5px 0;">Status</td>
                        <td>
                            @{
                                var sc = Model.Status?.ToLower() switch {
                                    "dispensed" => "badge-success",
                                    "pending"   => "badge-warn",
                                    "cancelled" => "badge-danger",
                                    _           => "badge-gray"
                                };
                            }
                            <span class="badge-cms @sc">@Model.Status</span>
                        </td>
                    </tr>
                    @if (!string.IsNullOrWhiteSpace(Model.Remarks))
                    {
                        <tr>
                            <td style="color:#64748b;padding:5px 0;vertical-align:top;">Remarks</td>
                            <td>@Model.Remarks</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="cms-card h-100">
            <div class="cms-card-header">
                <span class="cms-card-title"><i class="fa-solid fa-pills"></i> Summary</span>
            </div>
            <div class="cms-card-body">
                <div style="font-size:32px;font-weight:700;color:#198754;">@items.Count()</div>
                <div style="font-size:13px;color:#64748b;">Medicine(s) prescribed</div>
                <div style="margin-top:12px;">
                    @if (Model.Status != null && (Model.Status.Equals("Dispensed", StringComparison.OrdinalIgnoreCase) || Model.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase)))
                    {
                        <span class="badge-cms badge-gray">
                            <i class="fa-solid fa-circle-check"></i> @Model.Status
                        </span>
                    }
                    else
                    {
                        <form asp-controller="MedicineDispensing" asp-action="DispenseAndBill" method="post"
                              onsubmit="return confirm('Dispense all medicines for this prescription? Stock will be deducted.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="prescriptionId" value="@Model.PrescriptionId" />
                            <button type="submit" class="btn-primary-cms btn-sm-cms">
                                <i class="fa-solid fa-hand-holding-medical"></i> Dispense This Prescription
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="cms-card">
    <div class="cms-card-header">
        <span class="cms-card-title"><i class="fa-solid fa-list"></i> Prescribed Medicines</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="cms-table">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Medicine</th>
                    <th>Dosage</th>
                    <th>Frequency</th>
                    <th>Duration</th>
                    <th>Qty</th>
                    <th>Instructions</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    int idx = 1;
                    @foreach (var item in items)
                    {
                        <tr>
                            <td style="color:#94a3b8;font-size:12px;">@idx++</td>
                            <td style="font-weight:600;">@item.MedicineName</td>
                            <td>@(item.Dosage ?? "—")</td>
                            <td>@(item.Frequency ?? "—")</td>
                            <td>@(item.Duration ?? "—")</td>
                            <td>
                                <span class="badge-cms badge-blue">@item.Quantity</span>
                            </td>
                            <td style="color:#64748b;">@(item.Instructions ?? "—")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:32px;color:#94a3b8;">
                            No medicines found for this prescription
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
